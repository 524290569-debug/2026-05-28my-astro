---
const navItems = [
  { label: "入口", href: "#home" },
  { label: "宣言", href: "#about" },
  { label: "现场", href: "#works" },
  { label: "档案", href: "#blog" },
  { label: "联络", href: "#contact" }
];
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path) => `${basePath}${path}`;

const assetLayers = [
  {
    name: "storm-sky",
    src: assetPath("assets/hero/sky-v5.webp"),
    depth: 0.025,
    className: "storm-sky-asset"
  },
  {
    name: "distant-city",
    src: assetPath("assets/hero/city-v5.webp"),
    depth: 0.14,
    className: "distant-city-asset"
  },
  {
    name: "foreground-rooftop",
    src: assetPath("assets/hero/rooftop-v5.webp"),
    depth: 0.42,
    className: "foreground-rooftop-asset"
  }
];
---

<section id="home" class="cyberpunk-hero" data-cyberpunk-hero>
  <header class="hero-nav" aria-label="主导航">
    <a class="hero-brand" href="#home" aria-label="灰雨电台入口">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>灰雨电台</span>
    </a>
    <nav class="hero-menu">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </header>

  <div class="hero-stage" aria-hidden="true">
    {
      assetLayers.map((layer) => (
        <div
          class={`asset-layer ${layer.className}`}
          data-depth={layer.depth}
          data-layer={layer.name}
        >
          <img src={layer.src} alt="" loading="eager" decoding="async" />
        </div>
      ))
    }
    <div class="city-haze-layer" data-depth="0.1"></div>
    <div class="css-rain-layer"></div>
    <div class="fog-gradient-layer"></div>
    <div class="grain-layer"></div>
    <div class="vignette-layer"></div>
  </div>

  <div class="hero-content">
    <p class="hero-kicker">后朋克 / 冷雨 / 屋顶回声</p>
    <h1>灰雨电台</h1>
    <p class="hero-copy">把失真的低频、潮湿的城市和未完成的夜晚收进一页。</p>
  </div>
</section>

<script>
  const hero = document.querySelector("[data-cyberpunk-hero]");

  if (hero) {
    const layers = Array.from(hero.querySelectorAll("[data-depth]"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let frame = 0;

    const setPointer = (clientX, clientY) => {
      const rect = hero.getBoundingClientRect();
      targetX = (clientX - rect.left) / Math.max(rect.width, 1) - 0.5;
      targetY = (clientY - rect.top) / Math.max(rect.height, 1) - 0.5;
    };

    const render = () => {
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      layers.forEach((layer) => {
        const depth = Number(layer.dataset.depth || 0);
        layer.style.transform = `translate3d(${-currentX * depth * 300}px, ${-currentY * depth * 170}px, 0)`;
      });

      frame = window.requestAnimationFrame(render);
    };

    hero.addEventListener("pointermove", (event) => setPointer(event.clientX, event.clientY), {
      passive: true
    });

    hero.addEventListener(
      "pointerleave",
      () => {
        targetX = 0;
        targetY = 0;
      },
      { passive: true }
    );

    if (!reduceMotion.matches) {
      frame = window.requestAnimationFrame(render);
    }

    window.addEventListener("beforeunload", () => window.cancelAnimationFrame(frame));
  }
</script>

---
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path) => `${basePath}${path}`;
const navItems = [
  { label: "入口", href: "#home", section: true },
  { label: "宣言", href: "#about", section: true },
  { label: "现场", href: "#works", section: true },
  { label: "档案", href: "#blog", section: true },
  { label: "联络", href: "#contact", section: true },
  { label: "巨构主义", href: `${basePath}megastructure/`, section: false }
];

const assetLayers = [
  {
    name: "storm-sky",
    src: assetPath("assets/hero/sky-v5.webp"),
    width: 1600,
    height: 686,
    depth: 0.025,
    className: "storm-sky-asset"
  },
  {
    name: "distant-city",
    src: assetPath("assets/hero/city-v5.webp"),
    width: 1600,
    height: 556,
    depth: 0.14,
    className: "distant-city-asset"
  },
  {
    name: "foreground-rooftop",
    src: assetPath("assets/hero/rooftop-v5.webp"),
    width: 1600,
    height: 267,
    depth: 0.42,
    className: "foreground-rooftop-asset"
  }
];

const stationReadouts = [
  {
    channel: "rain",
    label: "RAIN",
    value: "18 mm",
    detail: "雨声压低了频道",
    status: "RAIN / ON AIR",
    log: "雨线增密，远城退到雾后。"
  },
  {
    channel: "band",
    label: "BAND",
    value: "-72 dB",
    detail: "远处霓虹只保留残响",
    status: "BAND / HOLD",
    log: "频段收窄，只留下屋顶边缘的低频。"
  },
  {
    channel: "light",
    label: "LIGHT",
    value: "01",
    detail: "只留一格暖黄窗光",
    status: "LIGHT / LOW",
    log: "窗光上浮一格，雨幕保持低亮。"
  }
];
---

<section id="home" class="cyberpunk-hero" data-cyberpunk-hero data-channel="rain">
  <header class="hero-nav" aria-label="主导航">
    <a class="hero-brand" href="#home" aria-label="灰雨电台入口">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>灰雨电台</span>
    </a>
    <nav class="hero-menu" aria-label="页面分区">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            data-section-link={item.section ? "" : undefined}
            aria-current={item.section && item.href === "#home" ? "location" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </header>

  <div class="hero-stage" aria-hidden="true">
    {
      assetLayers.map((layer) => (
        <div
          class={`asset-layer ${layer.className}`}
          data-depth={layer.depth}
          data-layer={layer.name}
        >
          <img
            src={layer.src}
            alt=""
            width={layer.width}
            height={layer.height}
            loading="eager"
            decoding="async"
            fetchpriority={layer.name === "distant-city" ? "high" : "auto"}
            sizes="100vw"
            draggable="false"
          />
        </div>
      ))
    }
    <div class="city-haze-layer" data-depth="0.1"></div>
    <div class="css-rain-layer"></div>
    <div class="fog-gradient-layer"></div>
    <div class="grain-layer"></div>
    <div class="vignette-layer"></div>
  </div>

  <div class="hero-content">
    <p class="hero-kicker">后朋克 / 雨夜城市 / 低保真界面</p>
    <h1>灰雨电台</h1>
    <p class="hero-copy">
      一个把冷雨、失真低频和屋顶城市压进浏览器里的个人站点。
    </p>
    <div class="hero-actions" aria-label="主要入口">
      <a href="#works">查看现场</a>
      <a href="#blog">读取档案</a>
    </div>
    <div class="hero-signal" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>
    <aside class="hero-station-panel" aria-label="屋顶电台状态">
      <div class="station-panel-head">
        <span>ROOFTOP STATION</span>
        <strong data-channel-status>{stationReadouts[0].status}</strong>
      </div>
      <div class="station-panel-grid">
        {stationReadouts.map((readout) => (
          <button
            class="station-readout"
            type="button"
            data-channel-option={readout.channel}
            data-channel-status={readout.status}
            data-channel-log={readout.log}
            aria-pressed={readout.channel === "rain" ? "true" : "false"}
          >
            <span>{readout.label}</span>
            <strong>{readout.value}</strong>
            <p>{readout.detail}</p>
          </button>
        ))}
      </div>
      <p class="station-transmission-log" data-channel-log-output aria-live="polite">
        {stationReadouts[0].log}
      </p>
    </aside>
  </div>
</section>

<script>
  const hero = document.querySelector("[data-cyberpunk-hero]");

  if (hero) {
    const layers = Array.from(hero.querySelectorAll("[data-depth]"));
    const navLinks = Array.from(hero.querySelectorAll("[data-section-link]"));
    const channelButtons = Array.from(hero.querySelectorAll("[data-channel-option]"));
    const channelStatus = hero.querySelector("[data-channel-status]");
    const channelLog = hero.querySelector("[data-channel-log-output]");
    const navSections = navLinks
      .map((link) => {
        const id = link.hash ? link.hash.slice(1) : "";
        const section = id ? document.getElementById(id) : null;

        return section ? { id, link, section } : null;
      })
      .filter(Boolean);
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let frame = 0;
    let navFrame = 0;
    let interactionIdleTimer = 0;
    let activeSectionId = "";
    let lockedHashId = "";
    let hashLockUntil = 0;
    const idleThreshold = 0.001;
    const channelStorageKey = "gray-rain-radio-channel";
    const channelMeta = new Map(
      channelButtons.map((button) => [
        button.dataset.channelOption,
        {
          status: button.dataset.channelStatus || "",
          log: button.dataset.channelLog || ""
        }
      ])
    );

    const getStoredChannel = () => {
      try {
        return window.localStorage.getItem(channelStorageKey) || "";
      } catch {
        return "";
      }
    };

    const storeChannel = (channel) => {
      try {
        window.localStorage.setItem(channelStorageKey, channel);
      } catch {
        // localStorage can be unavailable in private or restricted contexts.
      }
    };

    const setChannel = (channel, shouldPersist = false) => {
      const fallbackChannel = channelButtons[0]?.dataset.channelOption || "rain";
      const nextChannel = channelMeta.has(channel) ? channel : fallbackChannel;
      const meta = channelMeta.get(nextChannel);

      hero.dataset.channel = nextChannel;

      channelButtons.forEach((button) => {
        button.setAttribute(
          "aria-pressed",
          button.dataset.channelOption === nextChannel ? "true" : "false"
        );
      });

      if (channelStatus && meta?.status) {
        channelStatus.textContent = meta.status;
      }

      if (channelLog && meta?.log) {
        channelLog.textContent = meta.log;
      }

      if (shouldPersist) {
        storeChannel(nextChannel);
      }
    };

    const setActiveSection = (id) => {
      if (!id || activeSectionId === id) {
        return;
      }

      activeSectionId = id;

      navSections.forEach(({ id: sectionId, link }) => {
        if (sectionId === id) {
          link.setAttribute("aria-current", "location");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    const setActiveSectionFromHash = () => {
      const hashId = window.location.hash
        ? decodeURIComponent(window.location.hash.slice(1))
        : "";
      const hasHashSection = navSections.some(({ id }) => id === hashId);

      if (hasHashSection) {
        lockedHashId = hashId;
        hashLockUntil = window.performance.now() + 1600;
        setActiveSection(hashId);
      }

      return hasHashSection;
    };

    const updateActiveSection = () => {
      if (!navSections.length) {
        return;
      }

      const anchorLine = window.innerHeight * 0.42;

      if (lockedHashId && window.performance.now() < hashLockUntil) {
        const lockedSection = navSections.find(({ id }) => id === lockedHashId)?.section;
        const lockedTop = lockedSection?.getBoundingClientRect().top;

        if (typeof lockedTop === "number" && Math.abs(lockedTop) > 140) {
          return;
        }
      }

      lockedHashId = "";
      let nextSectionId = navSections[0].id;

      navSections.forEach(({ id, section }) => {
        const rect = section.getBoundingClientRect();

        if (rect.top <= anchorLine) {
          nextSectionId = id;
        }
      });

      setActiveSection(nextSectionId);
    };

    const keepParallaxLayerWarm = () => {
      if (reduceMotion.matches) {
        return;
      }

      hero.classList.add("hero-is-interacting");

      if (interactionIdleTimer) {
        window.clearTimeout(interactionIdleTimer);
      }

      interactionIdleTimer = window.setTimeout(() => {
        interactionIdleTimer = 0;
        hero.classList.remove("hero-is-interacting");
      }, 900);
    };

    const scheduleNavUpdate = () => {
      if (navFrame) {
        return;
      }

      navFrame = window.requestAnimationFrame(() => {
        navFrame = 0;
        updateActiveSection();
      });
    };

    const setPointer = (clientX, clientY) => {
      const rect = hero.getBoundingClientRect();
      targetX = (clientX - rect.left) / Math.max(rect.width, 1) - 0.5;
      targetY = (clientY - rect.top) / Math.max(rect.height, 1) - 0.5;
    };

    const scheduleRender = () => {
      if (frame || reduceMotion.matches) {
        return;
      }

      frame = window.requestAnimationFrame(render);
    };

    const render = () => {
      frame = 0;
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      layers.forEach((layer) => {
        const depth = Number(layer.dataset.depth || 0);
        layer.style.transform = `translate3d(${-currentX * depth * 300}px, ${-currentY * depth * 170}px, 0)`;
      });

      if (Math.abs(targetX - currentX) > idleThreshold || Math.abs(targetY - currentY) > idleThreshold) {
        scheduleRender();
      }
    };

    hero.addEventListener(
      "pointermove",
      (event) => {
        keepParallaxLayerWarm();
        setPointer(event.clientX, event.clientY);
        scheduleRender();
      },
      { passive: true }
    );

    hero.addEventListener(
      "pointerleave",
      () => {
        keepParallaxLayerWarm();
        targetX = 0;
        targetY = 0;
        scheduleRender();
      },
      { passive: true }
    );

    if (channelButtons.length) {
      setChannel(getStoredChannel() || hero.dataset.channel || "rain");

      channelButtons.forEach((button) => {
        button.addEventListener("click", () => {
          setChannel(button.dataset.channelOption || "rain", true);
        });
      });
    }

    if (navSections.length) {
      if (!setActiveSectionFromHash()) {
        updateActiveSection();
      }

      window.addEventListener("scroll", scheduleNavUpdate, { passive: true });
      window.addEventListener("resize", scheduleNavUpdate, { passive: true });
      window.addEventListener(
        "hashchange",
        () => {
          setActiveSectionFromHash();
          scheduleNavUpdate();
        },
        { passive: true }
      );
    }

    window.addEventListener("beforeunload", () => {
      if (frame) {
        window.cancelAnimationFrame(frame);
      }

      if (navFrame) {
        window.cancelAnimationFrame(navFrame);
      }

      if (interactionIdleTimer) {
        window.clearTimeout(interactionIdleTimer);
      }
    });
  }
</script>

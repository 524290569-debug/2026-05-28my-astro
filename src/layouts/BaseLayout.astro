---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "云飞",
  description = "在雨夜赛博城市氛围里构建安静、清晰的个人网站。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

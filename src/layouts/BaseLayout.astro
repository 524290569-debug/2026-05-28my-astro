---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "YUNFEI",
  description = "Building quiet interfaces for a noisy future."
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

      color: var(--z-muted);
      font-size: 0.85rem;
      line-height: 1.75;
    }

    .zato-thesis {
      padding-bottom: 6rem;
    }

    .zato-thesis::before {
      position: absolute;
      z-index: -1;
      top: 4rem;
      right: -12rem;
      width: 34rem;
      height: 34rem;
      border: 1px solid rgba(211, 51, 133, 0.12);
      border-radius: 50%;
      background: repeating-radial-gradient(circle, transparent 0 1.8rem, rgba(211, 51, 133, 0.04) 1.85rem 1.92rem);
      content: "";
      opacity: 0.8;
    }

    .zato-thesis-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid rgba(240, 232, 220, 0.18);
      border-bottom: 1px solid rgba(240, 232, 220, 0.18);
    }

    .zato-thesis-card {
      min-height: 25rem;
      padding: 2rem;
      border-right: 1px solid rgba(240, 232, 220, 0.18);
      background:
        linear-gradient(180deg, rgba(211, 51, 133, 0.08), transparent 30%),
        rgba(255, 255, 255, 0.012);
    }

    .zato-thesis-card:last-child {
      border-right: 0;
    }

    .zato-thesis-card > span {
      color: var(--z-pink-bright);
      font-family: "Courier New", monospace;
      font-size: 0.66rem;
      letter-spacing: 0.1em;
    }

    .zato-thesis-card h3 {
      max-width: 12rem;
      margin: 6rem 0 1.2rem;
      color: #fff8ef;
      font-size: clamp(1.35rem, 2.2vw, 2rem);
      line-height: 1.25;
    }

    .zato-thesis-card p {
      margin: 0;
      color: var(--z-muted);
      font-size: 0.9rem;
      line-height: 1.9;
    }

    .zato-manifesto {
      position: relative;
      display: grid;
      max-width: 67rem;
      grid-template-columns: auto 1fr;
      gap: 1rem 2rem;
      margin: 7rem auto 0;
      padding: 0;
      border: 0;
    }

    .zato-manifesto > span {
      color: var(--z-pink);
      font-family: Georgia, serif;
      font-size: 8rem;
      line-height: 0.72;
    }

    .zato-manifesto p {
      margin: 0;
      color: #f3ece2;
      font-family: Georgia, "Songti SC", serif;
      font-size: clamp(1.35rem, 2.7vw, 2.45rem);
      line-height: 1.65;
    }

    .zato-manifesto footer {
      grid-column: 2;
      color: rgba(245, 240, 232, 0.34);
      font-family: "Courier New", monospace;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
    }

    .zato-world {
      position: relative;
      display: grid;
      min-height: 54rem;
      grid-template-columns: minmax(0, 1.35fr) minmax(25rem, 0.65fr);
      background: var(--z-paper);
      color: #171213;
    }

    .zato-world-image {
      position: relative;
      min-height: 54rem;
      overflow: hidden;
      background: #b7a9ba;
    }

    .zato-world-image::after {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, transparent 65%, rgba(241, 235, 224, 0.65)),
        repeating-linear-gradient(0deg, transparent 0 4px, rgba(22, 18, 19, 0.05) 4px 5px);
      content: "";
    }

    .zato-world-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: contrast(1.05) saturate(0.9);
      transform: scale(1.08);
    }

    .zato-world-coordinates {
      position: absolute;
      z-index: 2;
      bottom: 2rem;
      left: 2rem;
      border-left: 2px solid rgba(23, 18, 19, 0.82);
      padding-left: 1rem;
      color: rgba(23, 18, 19, 0.76);
      font-family: "Courier New", monospace;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      line-height: 1.7;
    }

    .zato-world-copy {
      position: relative;
      z-index: 2;
      align-self: center;
      padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem) clamp(3rem, 6vw, 6rem) 0;
    }

    .zato-world-copy h2 {
      color: #171213;
      font-size: clamp(3rem, 5.4vw, 6rem);
    }

    .zato-world-copy h2 span {
      color: #8e2155;
    }

    .zato-world-copy > p:not(.zato-kicker) {
      margin: 1.5rem 0 0;
      color: rgba(23, 18, 19, 0.72);
      font-size: 0.92rem;
      line-height: 1.95;
    }

    .zato-world-copy ul {
      margin: 2rem 0 0;
      padding: 0;
      border-top: 1px solid rgba(23, 18, 19, 0.26);
      list-style: none;
    }

    .zato-world-copy li {
      display: grid;
      grid-template-columns: 4.3rem 1fr;
      gap: 1rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid rgba(23, 18, 19, 0.18);
      font-family: "Courier New", "Microsoft YaHei", monospace;
      font-size: 0.76rem;
    }

    .zato-world-copy li span {
      color: #9c225d;
      font-weight: 800;
    }

    .zato-character-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .zato-character-card {
      --card-accent: #bd9250;
      position: relative;
      display: grid;
      min-height: 38rem;
      grid-template-columns: minmax(13rem, 0.78fr) minmax(16rem, 1.22fr);
      overflow: hidden;
      border: 1px solid rgba(240, 232, 220, 0.18);
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.028), transparent 42%),
        #0b0809;
    }

    .zato-character-card.is-cyan { --card-accent: #6f9d9f; }
    .zato-character-card.is-olive { --card-accent: #929050; }
    .zato-character-card.is-violet { --card-accent: #777397; }

    .zato-character-visual {
      position: relative;
      display: flex;
      min-width: 0;
      align-items: end;
      justify-content: center;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 58%, color-mix(in srgb, var(--card-accent) 38%, transparent), transparent 38%),
        repeating-linear-gradient(108deg, transparent 0 2.8rem, rgba(255, 255, 255, 0.03) 2.85rem 2.92rem),
        #100c0d;
    }

    .zato-character-visual::after {
      position: absolute;
      right: 0;
      bottom: 0;
      left: 0;
      height: 45%;
      background: linear-gradient(transparent, #0b0809);
      content: "";
    }

    .zato-character-visual > span {
      position: absolute;
      z-index: 2;
      top: 1rem;
      left: 1rem;
      color: var(--card-accent);
      font-family: Impact, sans-serif;
      font-size: 3rem;
      line-height: 1;
    }

    .zato-character-visual img {
      position: relative;
      z-index: 1;
      width: auto;
      max-width: 118%;
      height: 92%;
      object-fit: contain;
      object-position: center bottom;
      filter: drop-shadow(0 1rem 1.5rem rgba(0, 0, 0, 0.68));
      transform: translateY(1.5rem);
      transition: transform 260ms ease;
    }

    .zato-character-card:hover .zato-character-visual img {
      transform: translateY(0.7rem);
    }

    .zato-character-copy {
      align-self: end;
      padding: 2rem;
    }

    .zato-character-copy > p:first-child {
      margin: 0;
      color: var(--card-accent);
      font-family: "Arial Narrow", sans-serif;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.16em;
    }

    .zato-character-copy h3 {
      margin: 0.55rem 0 0.35rem;
      color: #fff8ef;
      font-family: Impact, "Arial Narrow", "Microsoft YaHei", sans-serif;
      font-size: clamp(2rem, 3.3vw, 3.6rem);
      font-weight: 900;
      line-height: 1;
    }

    .zato-character-copy strong {
      color: rgba(245, 240, 232, 0.52);
      font-size: 0.76rem;
      font-weight: 500;
    }

    .zato-character-copy > span {
      display: block;
      width: 3rem;
      height: 2px;
      margin: 1.4rem 0;
      background: var(--card-accent);
    }

    .zato-character-copy > p:last-child {
      margin: 0;
      color: var(--z-muted);
      font-size: 0.88rem;
      line-height: 1.9;
    }

    .zato-style {
      position: relative;
      display: grid;
      min-height: 68rem;
      grid-template-columns: minmax(22rem, 0.82fr) minmax(30rem, 1.18fr);
      overflow: hidden;
      background: #ebe5d9;
      color: #181213;
    }

    .zato-style::before {
      position: absolute;
      z-index: 1;
      inset: 0;
      opacity: 0.12;
      background:
        repeating-linear-gradient(112deg, transparent 0 4rem, #65133d 4.05rem 4.12rem),
        repeating-radial-gradient(ellipse at 20% 50%, transparent 0 3rem, rgba(101, 19, 61, 0.24) 3.05rem 3.1rem);
      content: "";
      pointer-events: none;
    }

    .zato-style-backdrop {
      position: relative;
      z-index: 2;
      min-height: 68rem;
      overflow: hidden;
      background: #a9b6cc;
    }

    .zato-style-backdrop::after {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent 60%, #ebe5d9 100%);
      content: "";
    }

    .zato-style-backdrop img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 28%;
      filter: saturate(0.94) contrast(1.02);
    }

    .zato-style-copy {
      position: relative;
      z-index: 3;
      padding: clamp(5rem, 9vw, 9rem) max(2rem, calc((100vw - 88rem) / 2)) 6rem clamp(2rem, 5vw, 5rem);
    }

    .zato-style .zato-section-head {
      display: block;
      margin-bottom: 4rem;
    }

    .zato-style .zato-section-head h2 {
      color: #181213;
    }

    .zato-style .zato-section-head h2 em {
      color: #9d225c;
    }

    .zato-style-list {
      border-top: 2px solid rgba(24, 18, 19, 0.72);
    }

    .zato-style-note {
      display: grid;
      grid-template-columns: 3rem 1fr;
      gap: 1.2rem;
      padding: 1.65rem 0;
      border-bottom: 1px solid rgba(24, 18, 19, 0.26);
    }

    .zato-style-note > span {
      color: #9d225c;
      font-family: Impact, sans-serif;
      font-size: 2rem;
    }

    .zato-style-note h3 {
      margin: 0;
      color: #181213;
      font-size: 1.1rem;
    }

    .zato-style-note p {
      margin: 0.55rem 0 0;
      color: rgba(24, 18, 19, 0.67);
      font-size: 0.84rem;
      line-height: 1.8;
    }

    .zato-gallery-grid {
      display: grid;
      grid-auto-rows: 15rem;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .zato-gallery-item {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(240, 232, 220, 0.18);
      background: #0c090a;
      padding: 0;
      color: inherit;
      cursor: zoom-in;
    }

    .zato-gallery-item-1 { grid-column: span 7; grid-row: span 2; }
    .zato-gallery-item-2 { grid-column: span 5; }
    .zato-gallery-item-3 { grid-column: span 5; }
    .zato-gallery-item-4 { grid-column: span 5; grid-row: span 2; }
    .zato-gallery-item-5 { grid-column: span 4; grid-row: span 2; }
    .zato-gallery-item-6 { grid-column: span 3; grid-row: span 2; }

    .zato-gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.82) contrast(1.04) brightness(0.84);
      transition: filter 240ms ease, transform 360ms ease;
    }

    .zato-gallery-item-1 img { object-position: center; }
    .zato-gallery-item-5 img { object-position: center 24%; }

    .zato-gallery-item::after {
      position: absolute;
      inset: 0;
      background: linear-gradient(transparent 42%, rgba(4, 3, 4, 0.9));
      content: "";
    }

    .zato-gallery-item > span {
      position: absolute;
      z-index: 2;
      right: 1rem;
      bottom: 1rem;
      left: 1rem;
      text-align: left;
    }

    .zato-gallery-item small {
      display: block;
      color: var(--z-pink-bright);
      font-family: "Courier New", monospace;
      font-size: 0.62rem;
      letter-spacing: 0.09em;
    }

    .zato-gallery-item strong {
      display: block;
      margin-top: 0.35rem;
      color: #fff8ee;
      font-size: 1rem;
    }

    .zato-gallery-item:hover img,
    .zato-gallery-item:focus-visible img {
      filter: saturate(1) contrast(1.04) brightness(0.98);
      transform: scale(1.035);
    }

    .zato-gallery-item:focus-visible {
      outline: 2px solid var(--z-pink-bright);
      outline-offset: 2px;
    }

    .zato-soundtrack-section {
      display: grid;
      width: min(88rem, calc(100% - 3rem));
      grid-template-columns: minmax(22rem, 0.72fr) minmax(30rem, 1.28fr);
      gap: 5rem;
      margin: 0 auto;
      padding: 5rem 0 11rem;
      border-top: 1px solid rgba(240, 232, 220, 0.18);
    }

    .zato-soundtrack-intro {
      position: sticky;
      top: 7rem;
      align-self: start;
    }

    .zato-soundtrack-intro h2 {
      font-size: clamp(3rem, 5vw, 5.5rem);
    }

    .zato-soundtrack-intro > p:not(:first-child) {
      max-width: 34rem;
      margin: 1.6rem 0 0;
      color: var(--z-muted);
      font-size: 0.9rem;
      line-height: 1.9;
    }

    .zato-soundtrack-intro > p strong {
      color: var(--z-pink-bright);
    }

    [data-tracklist-toggle] {
      display: inline-flex;
      min-height: 3rem;
      align-items: center;
      gap: 1.4rem;
      margin-top: 1.8rem;
      border: 1px solid rgba(240, 232, 220, 0.22);
      background: transparent;
      padding: 0 1rem;
      color: #fff5eb;
      font: inherit;
      font-size: 0.76rem;
      cursor: pointer;
    }

    [data-tracklist-toggle] span {
      color: var(--z-pink-bright);
      font-size: 1.1rem;
    }

    .zato-tracklist {
      display: grid;
      align-self: start;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border-top: 1px solid rgba(240, 232, 220, 0.18);
    }

    .zato-tracklist[hidden] {
      display: none;
    }

    .zato-tracklist button {
      display: grid;
      min-height: 3.6rem;
      grid-template-columns: 2.5rem minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 0;
      border-right: 1px solid rgba(240, 232, 220, 0.12);
      border-bottom: 1px solid rgba(240, 232, 220, 0.12);
      background: rgba(255, 255, 255, 0.012);
      padding: 0.65rem 0.8rem;
      color: var(--z-muted);
      text-align: left;
      cursor: pointer;
      transition: background 160ms ease, color 160ms ease;
    }

    .zato-tracklist button:nth-child(2n) {
      border-right: 0;
    }

    .zato-tracklist button span,
    .zato-tracklist button small {
      color: rgba(245, 240, 232, 0.34);
      font-family: "Courier New", monospace;
      font-size: 0.62rem;
    }

    .zato-tracklist button strong {
      overflow: hidden;
      font-size: 0.75rem;
      font-weight: 500;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .zato-tracklist button:hover,
    .zato-tracklist button:focus-visible,
    .zato-tracklist button[aria-pressed="true"] {
      background: rgba(211, 51, 133, 0.12);
      color: #fff8ef;
      outline: none;
    }

    .zato-tracklist button[aria-pressed="true"] span,
    .zato-tracklist button[aria-pressed="true"] small {
      color: var(--z-pink-bright);
    }

    .zato-footer {
      display: flex;
      width: min(88rem, calc(100% - 3rem));
      justify-content: space-between;
      gap: 3rem;
      align-items: end;
      margin: 0 auto;
      padding: 3rem 0 10rem;
      border-top: 1px solid rgba(240, 232, 220, 0.18);
    }

    .zato-footer img {
      width: min(18rem, 60vw);
      height: 4.5rem;
      object-fit: cover;
      object-position: center;
    }

    .zato-footer p {
      margin: 1rem 0 0;
      color: rgba(245, 240, 232, 0.4);
      font-size: 0.7rem;
    }

    .zato-footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem 1.2rem;
      justify-content: flex-end;
    }

    .zato-footer-links a {
      color: rgba(245, 240, 232, 0.6);
      font-family: "Courier New", monospace;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
    }

    .zato-footer-links a:hover,
    .zato-footer-links a:focus-visible {
      color: var(--z-pink-bright);
      outline: none;
    }

    .zato-player {
      position: fixed;
      z-index: 75;
      right: 1rem;
      bottom: 1rem;
      left: 1rem;
      display: grid;
      width: min(64rem, calc(100% - 2rem));
      min-height: 4.4rem;
      grid-template-columns: 4rem minmax(10rem, 0.9fr) auto minmax(13rem, 1.2fr) minmax(8rem, 0.5fr);
      gap: 1rem;
      align-items: center;
      margin: 0 auto;
      border: 1px solid rgba(240, 232, 220, 0.24);
      background: rgba(7, 4, 6, 0.94);
      padding: 0.6rem 0.8rem;
      backdrop-filter: blur(20px);
      box-shadow: 0 1rem 4rem rgba(0, 0, 0, 0.52);
      opacity: 0;
      transform: translateY(1rem);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .zato-player[data-ready="true"] {
      opacity: 1;
      transform: translateY(0);
    }

    .zato-player-signal {
      display: flex;
      height: 2rem;
      align-items: center;
      justify-content: center;
      gap: 0.24rem;
      border-right: 1px solid rgba(240, 232, 220, 0.16);
    }

    .zato-player-signal span {
      width: 2px;
      height: 22%;
      background: var(--z-pink-bright);
      transform-origin: center;
    }

    .zato-page[data-audio-playing="true"] .zato-player-signal span {
      animation: zato-wave 0.78s ease-in-out infinite alternate;
    }

    .zato-player-signal span:nth-child(2) { animation-delay: -0.32s !important; }
    .zato-player-signal span:nth-child(3) { animation-delay: -0.58s !important; }
    .zato-player-signal span:nth-child(4) { animation-delay: -0.18s !important; }
    .zato-player-signal span:nth-child(5) { animation-delay: -0.46s !important; }

    .zato-player-meta {
      min-width: 0;
    }

    .zato-player-meta small {
      display: block;
      color: var(--z-pink-bright);
      font-family: "Courier New", monospace;
      font-size: 0.57rem;
      letter-spacing: 0.08em;
    }

    .zato-player-meta strong {
      display: block;
      overflow: hidden;
      margin-top: 0.25rem;
      color: #fff8ef;
      font-size: 0.8rem;
      font-weight: 600;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .zato-player-controls {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    .zato-player-controls button,
    .zato-player-volume button {
      display: inline-flex;
      width: 2.2rem;
      height: 2.2rem;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(240, 232, 220, 0.18);
      background: transparent;
      color: rgba(245, 240, 232, 0.74);
      font: inherit;
      cursor: pointer;
    }

    .zato-player-controls .zato-player-play {
      border-color: rgba(240, 82, 158, 0.62);
      background: var(--z-pink);
      color: #fff;
    }

    .zato-player-controls button:hover,
    .zato-player-controls button:focus-visible,
    .zato-player-volume button:hover,
    .zato-player-volume button:focus-visible {
      border-color: #fff;
      outline: none;
    }

    .zato-player-timeline,
    .zato-player-volume {
      display: flex;
      min-width: 0;
      align-items: center;
      gap: 0.55rem;
    }

    .zato-player-timeline span {
      color: rgba(245, 240, 232, 0.4);
      font-family: "Courier New", monospace;
      font-size: 0.58rem;
    }

    .zato-player input[type="range"] {
      min-width: 0;
      height: 2px;
      flex: 1;
      appearance: none;
      background: rgba(240, 232, 220, 0.22);
      cursor: pointer;
    }

    .zato-player input[type="range"]::-webkit-slider-thumb {
      width: 0.68rem;
      height: 0.68rem;
      border: 0;
      border-radius: 0;
      appearance: none;
      background: var(--z-pink-bright);
      transform: rotate(45deg);
    }

    .zato-player input[type="range"]::-moz-range-thumb {
      width: 0.68rem;
      height: 0.68rem;
      border: 0;
      border-radius: 0;
      background: var(--z-pink-bright);
      transform: rotate(45deg);
    }

    .zato-player-volume button {
      width: 2.8rem;
      font-family: "Courier New", monospace;
      font-size: 0.56rem;
    }

    .zato-audio-unlock {
      position: fixed;
      z-index: 76;
      top: 5.6rem;
      left: 50%;
      display: inline-flex;
      min-height: 3rem;
      align-items: center;
      gap: 0.75rem;
      border: 1px solid rgba(240, 82, 158, 0.7);
      background: rgba(88, 16, 49, 0.94);
      padding: 0 1rem;
      color: #fff8ef;
      font: inherit;
      font-size: 0.72rem;
      cursor: pointer;
      box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.45);
      transform: translateX(-50%);
    }

    .zato-audio-unlock[hidden] {
      display: none;
    }

    .zato-lightbox {
      width: min(78rem, calc(100% - 2rem));
      max-width: none;
      max-height: calc(100svh - 2rem);

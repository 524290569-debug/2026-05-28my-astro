---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path: string) => `${basePath}${path}`;
const heroVideoParts = [1, 2, 3, 4].map((part) =>
  assetPath(`assets/zato/video/op.webm.part${String(part).padStart(2, "0")}`)
);

const navItems = [
  { label: "信号", href: "#signal" },
  { label: "封闭城市", href: "#world" },
  { label: "人物", href: "#characters" },
  { label: "视觉语言", href: "#style" },
  { label: "艺术窗口", href: "#gallery" }
];

const thesisCards = [
  {
    code: "01 / IMPROBABLE",
    title: "世界不是理所当然",
    body: "故事从恒星、雪与偶然谈起：生命得以存在，本身就是一串近乎荒谬的巧合。Z.A.T.O. 把这种惊叹与恐惧并置，让“爱世界”不再是轻飘飘的乐观，而是一种清醒后的选择。"
  },
  {
    code: "02 / SIGNAL",
    title: "被看见，才算存在吗",
    body: "封闭城市、无线电、窗外的鸟和无人回应的独白共同追问：当一个人没有被理解、没有被认真倾听时，她的感受是否仍然真实？发出信号，本身就是对沉默的抵抗。"
  },
  {
    code: "03 / EVERYTHING",
    title: "把自己也算进万物",
    body: "页面把游戏的情感核心理解为：若要爱世界与其中的一切，就不能永远把自己排除在外。接纳并不抹平伤口，而是承认破碎、矛盾和不完美也属于完整的人。"
  }
];

const characters = [
  {
    id: "asya",
    name: "阿莎雅·舒比娜",
    en: "ASYA SHUBINA",
    role: "观察者 / 信号发送者",
    image: assetPath("assets/zato/images/characters/asya.png"),
    color: "amber",
    body: "安静、怯弱、被同龄人忽视的局外人。她会从太阳的亮点想到宇宙的善意，也会把别人的恶意解释成无伤大雅的玩笑。伊拉失踪后，只有她愿意继续追问。"
  },
  {
    id: "ira",
    name: "伊拉·格拉切夫斯卡娅",
    en: "IRA GRACHEVSKAYA",
    role: "失踪者 / 故事引力中心",
    image: assetPath("assets/zato/images/characters/ira.png"),
    color: "cyan",
    body: "逃课、难以接近、名声糟糕的“问题学生”。她的失踪撕开了小城习以为常的冷漠，也迫使阿莎雅重新理解那些被传言和标签覆盖的人。"
  },
  {
    id: "marina",
    name: "玛丽娜",
    en: "MARINA",
    role: "同行者 / 明亮表象",
    image: assetPath("assets/zato/images/characters/marina.png"),
    color: "olive",
    body: "外向、受欢迎、看起来总能把气氛带起来；但她对世界的判断远比笑容更冷。她让调查从孤独的执念，逐渐变成两个人共同确认现实的过程。"
  },
  {
    id: "vadim",
    name: "瓦季姆·加林",
    en: "VADIM GARIN",
    role: "同学 / 不可靠的噪声",
    image: assetPath("assets/zato/images/characters/vadim.png"),
    color: "violet",
    body: "以挖苦和欺负弱者取乐的男生，尤其喜欢拿阿莎雅开玩笑。随着小城里的异常逐渐显形，他的家庭也成为另一段失真的信号。"
  }
];

const styleNotes = [
  {
    number: "A",
    title: "手绘人物 × 粗粝实景",
    body: "可爱的高表情角色立绘被放进颗粒感强、近似旧照片的背景里。人物像仍在努力保持柔软，城市却早已变成一张冰冷而不可信的证据。"
  },
  {
    number: "B",
    title: "黑、洋红与苏联棕",
    body: "主界面的黑与洋红木纹负责制造精神性的涡流；校服棕、旧纸白、雪夜蓝把故事重新压回 1986 年的日常。鲜亮色只在信号越界时突然爆发。"
  },
  {
    number: "C",
    title: "没有选项的线性叙事",
    body: "游戏不提供选择，结局预先确定。失去“玩家控制权”不是功能缺失，而是形式的一部分：你只能陪阿莎雅继续看、继续听，直到信号抵达终点。"
  },
  {
    number: "D",
    title: "从生活切片滑向宇宙恐惧",
    body: "咖啡、教室、楼道和雪地先建立亲密的日常，再由重复、闪烁、无线电与过曝意象慢慢扭曲现实。恐怖并非突然出现，它一直藏在熟悉事物的纹理里。"
  }
];

const galleryItems = [
  {
    src: assetPath("assets/zato/images/backgrounds/polar-night.png"),
    alt: "粉蓝颗粒质感的沃尔库塔极夜雪原",
    code: "BG / POLAR NIGHT",
    title: "极夜并不完全是黑色",
    body: "粉蓝天空、雪粒与远处低伏的城市轮廓，让封闭感显得辽阔而不是狭窄。"
  },
  {
    src: assetPath("assets/zato/images/backgrounds/nii.png"),
    alt: "游戏中的封闭研究设施外景",
    code: "BG / NII",
    title: "研究设施",
    body: "制度化空间被处理成低清、潮湿的摄影证据；真实感越强，异常就越难被解释。"
  },
  {
    src: assetPath("assets/zato/images/gallery/mirror.png"),
    alt: "阿莎雅面对镜头微笑的游戏插画",
    code: "CG / MIRROR",
    title: "镜面练习",
    body: "角色直视画面时，玩家与人物之间安全的旁观距离会被短暂打破。"
  },
  {
    src: assetPath("assets/zato/images/gallery/tea-time-cafe.png"),
    alt: "伊拉与玛丽娜在咖啡馆的游戏插画",
    code: "CG / TEA TIME",
    title: "生活仍在发生",
    body: "温暖的室内光没有消解不安，反而证明这群人曾经拥有普通、细小而具体的时刻。"
  },
  {
    src: assetPath("assets/zato/images/artbook/smile.png"),
    alt: "阿莎雅、伊拉与玛丽娜合影般的艺术集插画",
    code: "ART PACK / SMILE",
    title: "把三个人留在同一张照片里",
    body: "艺术集以更松弛的笔触保留角色关系，让正篇之外的可能性继续存在。"
  },
  {
    src: assetPath("assets/zato/images/backgrounds/signal-line.png"),
    alt: "繁星与白色轨迹构成的宇宙信号画面",
    code: "BG / SIGNAL LINE",
    title: "向宇宙发送",
    body: "白色轨迹切过繁星，把非常私人、非常微小的声音送往无法确认的接收者。"
  }
];

const soundtrack = [
  ["Ambient 9", "01-ambient-9.mp3"],
  ["Clouds", "02-clouds.mp3"],
  ["Let’s Have a Good Day", "03-lets-have-a-good-day.mp3"],
  ["I Don’t Like You", "04-i-dont-like-you.ogg"],
  ["Good Mood", "05-good-mood.mp3"],
  ["Antics", "06-antics.ogg"],
  ["Pray", "07-pray.mp3"],
  ["A New Path", "08-a-new-path.mp3"],
  ["Child", "09-child.ogg"],
  ["Under a Canopy", "10-under-a-canopy.mp3"],
  ["Comfort", "11-comfort.ogg"],
  ["Machine", "12-machine.ogg"],
  ["Lullaby", "13-lullaby.mp3"],
  ["Cafe", "14-cafe.ogg"],
  ["Hate Me", "15-hate-me.mp3"],
  ["Slow Snow", "16-slow-snow.ogg"],
  ["Smoke", "17-smoke.ogg"],
  ["Dark", "18-dark.mp3"],
  ["Swimming in the Clouds", "19-swimming-in-the-clouds.mp3"],
  ["Everything Is Paradox", "20-everything-is-paradox.mp3"],
  ["Tosya", "21-tosya.ogg"],
  ["Mystery", "22-mystery.ogg"],
  ["Film", "23-film.ogg"],
  ["Tightrope", "24-tightrope.mp3"],
  ["Signal", "25-signal.ogg"],
  ["Step", "26-step.ogg"],
  ["Concerto Grosso No. 1 — Segment", "27-concerto-grosso-segment.mp3"],
  ["Kitchen", "28-kitchen.ogg"],
  ["Light", "29-light.ogg"],
  ["NII", "30-nii.ogg"],
  ["Above the Mountains", "31-above-the-mountains.mp3"],
  ["Menu", "32-menu.ogg"]
].map(([title, file], index) => ({
  index,
  number: String(index + 1).padStart(2, "0"),
  title,
  src: assetPath(`assets/zato/music/${file}`)
}));

const initialTrack = soundtrack[31];
---

<BaseLayout
  title="Z.A.T.O.｜我爱世界，以及其中的一切"
  description="Z.A.T.O. // I Love the World and Everything In It 的无剧透概念展示：封闭城市、人物、主题、视觉语言与官方原声。"
  image="assets/zato/images/artbook/title-screen.png"
  imageAlt="Z.A.T.O. 主角阿莎雅躺在雪地中的标题画面"
  imageWidth={998}
  imageHeight={720}
  imageType="image/png"
  skipTarget="#zato-main"
  preloadImages={[
    { href: "assets/zato/images/artbook/title-screen.png", type: "image/png", fetchPriority: "high" }
  ]}
>
  <div class="zato-page" data-zato-page>
    <header class="zato-topbar" data-zato-topbar>
      <a class="zato-home" href={basePath} aria-label="返回灰雨电台首页">
        <span aria-hidden="true"></span>
        灰雨电台
      </a>
      <nav class="zato-nav" aria-label="Z.A.T.O. 页面导航">
        {navItems.map((item) => (
          <a href={item.href} data-zato-nav-link>{item.label}</a>
        ))}
      </nav>
      <a class="zato-mega-link" href={`${basePath}megastructure/`}>巨构主义</a>
    </header>

    <main id="zato-main">
      <section class="zato-hero" aria-labelledby="zato-title">
        <div class="zato-hero-media" aria-hidden="true">
          <video
            data-zato-hero-video
            data-video-parts={JSON.stringify(heroVideoParts)}
            autoplay
            muted
            loop
            playsinline
            preload="none"
            poster={assetPath("assets/zato/images/artbook/title-screen.png")}
          ></video>
          <div class="zato-hero-veil"></div>
          <div class="zato-scanlines"></div>
        </div>

        <div class="zato-hero-copy">
          <p class="zato-eyebrow">CLOSED CITY / VORKUTA-5 / 1986</p>
          <img
            class="zato-logo"
            src={assetPath("assets/zato/images/ui/zato-title.png")}
            width="1280"
            height="720"
            alt="Z.A.T.O."
            decoding="async"
          />
          <h1 id="zato-title">我爱世界，以及其中的一切</h1>
          <p class="zato-hero-intro">
            伊拉失踪了，没有人关心。阿莎雅决定继续寻找。案件只是入口——真正被追问的，是人在孤独、伤害与自我否定之间，是否仍能爱这个世界，并把自己也算进“万物”之中。
          </p>
          <div class="zato-hero-actions">
            <a href="#signal">接收信号</a>
            <button type="button" data-audio-hero-toggle>
              <span data-audio-hero-icon aria-hidden="true">▶</span>
              <span data-audio-hero-label>播放原声</span>
            </button>
          </div>
        </div>

        <aside class="zato-case-file" aria-label="游戏信息">
          <span>CASE FILE / 1986-ЗАТО</span>
          <dl>
            <div><dt>地点</dt><dd>沃尔库塔-5</dd></div>
            <div><dt>类型</dt><dd>线性视觉小说</dd></div>
            <div><dt>时长</dt><dd>约 7–8 小时</dd></div>
            <div><dt>选择</dt><dd>0 / 结局既定</dd></div>
          </dl>
        </aside>

        <div class="zato-scroll-cue" aria-hidden="true">
          <span></span>
          KEEP RECEIVING
        </div>
      </section>

      <section id="signal" class="zato-section zato-thesis" data-zato-section>
        <div class="zato-section-head zato-reveal">
          <p>01 / CENTRAL TRANSMISSION</p>
          <h2>这不是一份失踪案摘要。<br /><em>这是一段关于如何继续去爱的信号。</em></h2>
          <div class="zato-head-note">
            <span>无关键剧情剧透</span>
            <p>以下内容只整理游戏公开设定、开篇命题与视觉语言，不解释谜底。</p>
          </div>
        </div>

        <div class="zato-thesis-grid">
          {thesisCards.map((card) => (
            <article class="zato-thesis-card zato-reveal">
              <span>{card.code}</span>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>

        <blockquote class="zato-manifesto zato-reveal">
          <span aria-hidden="true">“</span>
          <p>爱世界并不等于否认它的残酷；它意味着看见残酷之后，仍愿意承认微小事物值得被珍惜——包括那个一直被自己遗漏的人。</p>
          <footer>CONCEPT READING / NOT A DIRECT QUOTE</footer>
        </blockquote>
      </section>

      <section id="world" class="zato-world" data-zato-section>
        <div class="zato-world-image">
          <img
            src={assetPath("assets/zato/images/backgrounds/polar-night.png")}
            width="1280"
            height="720"
            alt="粉蓝极夜中的雪原与远城"
            loading="lazy"
            decoding="async"
          />
          <div class="zato-world-coordinates" aria-hidden="true">
            67°30′N<br />VORKUTA-5<br />SIGNAL: UNSTABLE
          </div>
        </div>
        <div class="zato-world-copy zato-reveal">
          <p class="zato-kicker">02 / A TOWN THAT DOESN'T EXIST</p>
          <h2>封闭城市<br /><span>也是封闭的人。</span></h2>
          <p>
            1986 年，苏联北方的虚构封闭城市“沃尔库塔-5”。ZATO 原指封闭行政区：地图上的空白、被限制的出入、围绕敏感设施建立的生活共同体。游戏把这种制度性隔离转化为人物的心理地形。
          </p>
          <p>
            教室、住宅楼、咖啡馆、研究设施与冻原都是真实可触的日常；但每个人似乎都困在自己的解释系统里。伊拉的失踪没有立刻打破秩序——更可怕的是，秩序选择继续运转。
          </p>
          <ul>
            <li><span>气候</span>极夜 / 雪 / 低温颗粒</li>
            <li><span>介质</span>无线电 / 电话 / 窗 / 传言</li>
            <li><span>压力</span>沉默 / 标签 / 无人回应</li>
          </ul>
        </div>
      </section>

      <section id="characters" class="zato-section zato-characters" data-zato-section>
        <div class="zato-section-head zato-reveal">
          <p>03 / PEOPLE INSIDE THE SIGNAL</p>
          <h2>不是“功能角色”，<br /><em>而是四种与世界相处的方式。</em></h2>
        </div>

        <div class="zato-character-grid">
          {characters.map((character, index) => (
            <article class={`zato-character-card is-${character.color} zato-reveal`}>
              <div class="zato-character-visual">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <img
                  src={character.image}
                  width={character.id === "asya" ? "414" : "450"}
                  height="720"
                  alt={`${character.name}人物立绘`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="zato-character-copy">
                <p>{character.en}</p>
                <h3>{character.name}</h3>
                <strong>{character.role}</strong>
                <span></span>
                <p>{character.body}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="style" class="zato-style" data-zato-section>
        <div class="zato-style-backdrop" aria-hidden="true">
          <img
            src={assetPath("assets/zato/images/artbook/flower.png")}
            width="2049"
            height="3000"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="zato-style-copy">
          <div class="zato-section-head zato-reveal">
            <p>04 / VISUAL & NARRATIVE LANGUAGE</p>
            <h2>柔软的线条，<br /><em>不可靠的现实。</em></h2>
          </div>
          <div class="zato-style-list">
            {styleNotes.map((note) => (
              <article class="zato-style-note zato-reveal">
                <span>{note.number}</span>
                <div>
                  <h3>{note.title}</h3>
                  <p>{note.body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="gallery" class="zato-section zato-gallery" data-zato-section>
        <div class="zato-section-head zato-reveal">
          <p>05 / WINDOWS FROM VORKUTA-5</p>
          <h2>艺术窗口</h2>
          <div class="zato-head-note">
            <span>GAME + DIGITAL ART PACK</span>
            <p>点击图像可放大。这里优先选择不暴露谜底、但能代表色彩与质感的画面。</p>
          </div>
        </div>

        <div class="zato-gallery-grid">
          {galleryItems.map((item, index) => (
            <button
              class={`zato-gallery-item zato-gallery-item-${index + 1} zato-reveal`}
              type="button"
              data-gallery-open
              data-gallery-src={item.src}
              data-gallery-alt={item.alt}
              data-gallery-code={item.code}
              data-gallery-title={item.title}
              data-gallery-body={item.body}
              aria-label={`放大查看：${item.title}`}
            >
              <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
              <span>
                <small>{item.code}</small>
                <strong>{item.title}</strong>
              </span>
            </button>
          ))}
        </div>
      </section>

      <section class="zato-soundtrack-section" aria-labelledby="soundtrack-title">
        <div class="zato-soundtrack-intro zato-reveal">
          <p>06 / ROYALTY-FREE SOUNDTRACK</p>
          <h2 id="soundtrack-title">32 段声音，<br /><em>同一座不存在的小城。</em></h2>
          <p>
            已从本地游戏资源中整理完整 32 曲原声。页面默认从 <strong>Menu</strong> 开始播放；底部播放器可暂停、切歌和调整音量。
          </p>
          <button type="button" data-tracklist-toggle aria-expanded="false" aria-controls="zato-tracklist">
            查看完整曲目
            <span aria-hidden="true">＋</span>
          </button>
        </div>
        <div id="zato-tracklist" class="zato-tracklist" hidden>
          {soundtrack.map((track) => (
            <button
              type="button"
              data-track-option
              data-track-index={track.index}
              data-track-src={track.src}
              data-track-title={track.title}
              aria-pressed={track.index === initialTrack.index ? "true" : "false"}
            >
              <span>{track.number}</span>
              <strong>{track.title}</strong>
              <small>PLAY</small>
            </button>
          ))}
        </div>
      </section>

      <footer class="zato-footer">
        <div>
          <img
            src={assetPath("assets/zato/images/ui/zato-title.png")}
            width="1280"
            height="720"
            alt="Z.A.T.O."
            loading="lazy"
            decoding="async"
          />
          <p>非官方概念展示页 / 页面素材来自本地正版游戏与 Digital Art Pack。</p>
        </div>
        <div class="zato-footer-links">
          <a href="https://store.steampowered.com/app/4122860/ZATO__I_Love_the_World_and_Everything_In_It/" target="_blank" rel="noreferrer">STEAM ↗</a>
          <a href="https://nopanamaman.itch.io/z-a-t-o-i-love-the-world-and-everything-in-it" target="_blank" rel="noreferrer">ITCH.IO ↗</a>
          <a href={basePath}>返回灰雨电台</a>
        </div>
      </footer>
    </main>

    <audio
      data-zato-audio
      src={initialTrack.src}
      preload="metadata"
      autoplay
    ></audio>

    <aside class="zato-player" data-zato-player aria-label="Z.A.T.O. 原声播放器">
      <div class="zato-player-signal" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="zato-player-meta">
        <small data-audio-state>WAITING / AUTOPLAY</small>
        <strong data-audio-title>{initialTrack.title}</strong>
      </div>
      <div class="zato-player-controls">
        <button type="button" data-audio-prev aria-label="上一首">‹</button>
        <button class="zato-player-play" type="button" data-audio-toggle aria-label="播放">
          <span data-audio-play-icon aria-hidden="true">▶</span>
        </button>
        <button type="button" data-audio-next aria-label="下一首">›</button>
      </div>
      <div class="zato-player-timeline">
        <span data-audio-current>00:00</span>
        <input data-audio-progress type="range" min="0" max="100" value="0" step="0.1" aria-label="播放进度" />
        <span data-audio-duration>00:00</span>
      </div>
      <div class="zato-player-volume">
        <button type="button" data-audio-mute aria-label="静音">VOL</button>
        <input data-audio-volume type="range" min="0" max="1" value="0.42" step="0.01" aria-label="音量" />
      </div>
    </aside>

    <button class="zato-audio-unlock" type="button" data-audio-unlock hidden>
      <span aria-hidden="true">▶</span>
      浏览器拦截了有声自动播放，点击接入原声
    </button>

    <dialog class="zato-lightbox" data-gallery-dialog aria-labelledby="zato-lightbox-title">
      <button class="zato-lightbox-close" type="button" data-gallery-close aria-label="关闭大图">×</button>
      <div class="zato-lightbox-media">
        <img
          data-gallery-image
          src={assetPath("assets/zato/images/artbook/title-screen.png")}
          alt=""
        />
      </div>
      <div class="zato-lightbox-copy">
        <span data-gallery-dialog-code></span>
        <h2 id="zato-lightbox-title" data-gallery-dialog-title></h2>
        <p data-gallery-dialog-body></p>
      </div>
    </dialog>
  </div>

  <script>
    const page = document.querySelector("[data-zato-page]");

    if (page) {
      const heroVideo = page.querySelector("[data-zato-hero-video]");
      const audio = page.querySelector("[data-zato-audio]");
      const player = page.querySelector("[data-zato-player]");
      const playButtons = [
        page.querySelector("[data-audio-toggle]"),
        page.querySelector("[data-audio-hero-toggle]")
      ].filter(Boolean);
      const playIcon = page.querySelector("[data-audio-play-icon]");
      const heroIcon = page.querySelector("[data-audio-hero-icon]");
      const heroLabel = page.querySelector("[data-audio-hero-label]");
      const titleOutput = page.querySelector("[data-audio-title]");
      const stateOutput = page.querySelector("[data-audio-state]");
      const currentOutput = page.querySelector("[data-audio-current]");
      const durationOutput = page.querySelector("[data-audio-duration]");
      const progress = page.querySelector("[data-audio-progress]");
      const volume = page.querySelector("[data-audio-volume]");
      const muteButton = page.querySelector("[data-audio-mute]");
      const unlockButton = page.querySelector("[data-audio-unlock]");
      const trackButtons = Array.from(page.querySelectorAll("[data-track-option]"));
      const navLinks = Array.from(page.querySelectorAll("[data-zato-nav-link]"));
      const revealItems = Array.from(page.querySelectorAll(".zato-reveal"));
      let activeTrackIndex = 31;
      let audioUnlocked = false;

      const loadHeroVideo = async () => {
        if (!heroVideo) return;

        try {
          const partUrls = JSON.parse(heroVideo.dataset.videoParts || "[]");
          const responses = await Promise.all(partUrls.map((url) => fetch(url)));
          if (responses.some((response) => !response.ok)) {
            throw new Error("Video fragment request failed");
          }

          const fragments = await Promise.all(responses.map((response) => response.arrayBuffer()));
          const objectUrl = URL.createObjectURL(new Blob(fragments, { type: "video/webm" }));
          heroVideo.src = objectUrl;
          await heroVideo.play().catch(() => {});
          window.addEventListener("pagehide", () => URL.revokeObjectURL(objectUrl), { once: true });
        } catch {
          heroVideo.removeAttribute("src");
        }
      };

      loadHeroVideo();

      const formatTime = (value) => {
        if (!Number.isFinite(value)) return "00:00";
        const minutes = Math.floor(value / 60);
        const seconds = Math.floor(value % 60);
        return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
      };

      const setPlayerState = () => {
        if (!audio) return;
        const playing = !audio.paused && !audio.ended;
        page.dataset.audioPlaying = playing ? "true" : "false";
        if (playIcon) playIcon.textContent = playing ? "Ⅱ" : "▶";
        if (heroIcon) heroIcon.textContent = playing ? "Ⅱ" : "▶";
        if (heroLabel) heroLabel.textContent = playing ? "暂停原声" : "播放原声";
        if (stateOutput) {
          stateOutput.textContent = playing
            ? `PLAYING / ${String(activeTrackIndex + 1).padStart(2, "0")} OF ${String(trackButtons.length).padStart(2, "0")}`
            : audioUnlocked
              ? "PAUSED / LOCAL"
              : "WAITING / AUTOPLAY";
        }
        playButtons.forEach((button) => {
          button.setAttribute("aria-label", playing ? "暂停" : "播放");
        });
      };

      const markTrack = (index) => {
        trackButtons.forEach((button) => {
          button.setAttribute(
            "aria-pressed",
            Number(button.dataset.trackIndex) === index ? "true" : "false"
          );
        });
      };

      const playCurrent = async () => {
        if (!audio) return false;
        try {
          await audio.play();
          audioUnlocked = true;
          if (unlockButton) unlockButton.hidden = true;
          setPlayerState();
          return true;
        } catch {
          if (unlockButton) unlockButton.hidden = false;
          setPlayerState();
          return false;
        }
      };

      const setTrack = async (index, shouldPlay = true) => {
        if (!audio || !trackButtons.length) return;
        const normalized = (index + trackButtons.length) % trackButtons.length;
        const option = trackButtons.find(
          (button) => Number(button.dataset.trackIndex) === normalized
        );
        if (!option) return;
        activeTrackIndex = normalized;
        audio.src = option.dataset.trackSrc || "";
        if (titleOutput) titleOutput.textContent = option.dataset.trackTitle || "Z.A.T.O.";
        markTrack(normalized);
        audio.load();
        if (shouldPlay) await playCurrent();
      };

      playButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          if (!audio) return;
          if (audio.paused) await playCurrent();
          else audio.pause();
          setPlayerState();
        });
      });

      page.querySelector("[data-audio-prev]")?.addEventListener("click", () => {
        setTrack(activeTrackIndex - 1);
      });
      page.querySelector("[data-audio-next]")?.addEventListener("click", () => {
        setTrack(activeTrackIndex + 1);
      });

      trackButtons.forEach((button) => {
        button.addEventListener("click", () => {
          setTrack(Number(button.dataset.trackIndex));
        });
      });

      audio?.addEventListener("play", setPlayerState);
      audio?.addEventListener("pause", setPlayerState);
      audio?.addEventListener("ended", () => setTrack(activeTrackIndex + 1));
      audio?.addEventListener("loadedmetadata", () => {
        if (durationOutput) durationOutput.textContent = formatTime(audio.duration);
      });
      audio?.addEventListener("timeupdate", () => {
        if (currentOutput) currentOutput.textContent = formatTime(audio.currentTime);
        if (progress && Number.isFinite(audio.duration) && audio.duration > 0) {
          progress.value = String((audio.currentTime / audio.duration) * 100);
        }
      });

      progress?.addEventListener("input", () => {
        if (!audio || !Number.isFinite(audio.duration)) return;
        audio.currentTime = (Number(progress.value) / 100) * audio.duration;
      });

      const storedVolume = Number(window.localStorage.getItem("zato-audio-volume"));
      if (audio && volume) {
        const initialVolume = Number.isFinite(storedVolume) && storedVolume >= 0 && storedVolume <= 1
          ? storedVolume
          : Number(volume.value);
        audio.volume = initialVolume;
        volume.value = String(initialVolume);
      }

      volume?.addEventListener("input", () => {
        if (!audio) return;
        audio.volume = Number(volume.value);
        audio.muted = false;
        window.localStorage.setItem("zato-audio-volume", String(audio.volume));
        if (muteButton) muteButton.textContent = "VOL";
      });

      muteButton?.addEventListener("click", () => {
        if (!audio) return;
        audio.muted = !audio.muted;
        muteButton.textContent = audio.muted ? "MUTE" : "VOL";
      });

      const unlockAudio = async () => {
        if (!audio || !audio.paused || audioUnlocked) return;
        await playCurrent();
      };

      unlockButton?.addEventListener("click", playCurrent);
      window.addEventListener("pointerdown", unlockAudio, { once: true });
      window.addEventListener("keydown", unlockAudio, { once: true });
      window.setTimeout(playCurrent, 120);

      const tracklistToggle = page.querySelector("[data-tracklist-toggle]");
      const tracklist = document.getElementById("zato-tracklist");
      tracklistToggle?.addEventListener("click", () => {
        if (!tracklist) return;
        const willOpen = tracklist.hidden;
        tracklist.hidden = !willOpen;
        tracklistToggle.setAttribute("aria-expanded", String(willOpen));
        const icon = tracklistToggle.querySelector("span");
        if (icon) icon.textContent = willOpen ? "−" : "＋";
      });

      const dialog = page.querySelector("[data-gallery-dialog]");
      const dialogImage = page.querySelector("[data-gallery-image]");
      const dialogCode = page.querySelector("[data-gallery-dialog-code]");
      const dialogTitle = page.querySelector("[data-gallery-dialog-title]");
      const dialogBody = page.querySelector("[data-gallery-dialog-body]");

      page.querySelectorAll("[data-gallery-open]").forEach((button) => {
        button.addEventListener("click", () => {
          if (!dialog || !dialogImage) return;
          dialogImage.src = button.dataset.gallerySrc || "";
          dialogImage.alt = button.dataset.galleryAlt || "";
          if (dialogCode) dialogCode.textContent = button.dataset.galleryCode || "";
          if (dialogTitle) dialogTitle.textContent = button.dataset.galleryTitle || "";
          if (dialogBody) dialogBody.textContent = button.dataset.galleryBody || "";
          dialog.showModal();
        });
      });
      page.querySelector("[data-gallery-close]")?.addEventListener("click", () => dialog?.close());
      dialog?.addEventListener("click", (event) => {
        if (event.target === dialog) dialog.close();
      });

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.id;
            navLinks.forEach((link) => {
              if (link.hash === `#${id}`) link.setAttribute("aria-current", "location");
              else link.removeAttribute("aria-current");
            });
          });
        },
        { rootMargin: "-30% 0px -62%", threshold: 0 }
      );
      page.querySelectorAll("[data-zato-section][id]").forEach((section) => sectionObserver.observe(section));

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -8%", threshold: 0.08 }
        );
        revealItems.forEach((item) => revealObserver.observe(item));
      }

      setPlayerState();
      markTrack(activeTrackIndex);
      if (player) player.dataset.ready = "true";
    }
  </script>


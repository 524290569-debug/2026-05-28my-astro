const deskImageSize = { width: 1200, height: 900 };
---

<BaseLayout
  title="灰雨电台 - 雨夜后朋克个人站"
  description="一个后朋克、雨夜城市、低保真视觉与前端实验交织的个人网站。"
  preloadImages={[
    { href: "assets/hero/city-v5.webp", type: "image/webp", fetchPriority: "high" }
  ]}
>
  <main
    class="page-shell page-shell-visual"
    data-page-signal
    data-ambient-tone="home"
    style={`--rain-wall: url("${textureImage}")`}
  >
    <CyberpunkHero />

    <section class="surface-brief" aria-label="频道状态">
      <div class="brief-track">
        <div>
          <span>频率</span>
          <strong>03:17 / 冷雨在线</strong>
        </div>
        <div>
          <span>位置</span>
          <strong>旧楼天台 / 北向窗</strong>
        </div>
        <div>
          <span>声场</span>
          <strong>后朋克 / 低保真 / 工业噪声</strong>
        </div>
        <div>
          <span>状态</span>
          <strong>低亮度维护中</strong>
        </div>
      </div>
    </section>

    <section class="signal-tape" aria-label="弱信号层">
      <div class="signal-tape-inner">
        <div class="signal-tape-meter" aria-hidden="true">
          <span style="--level: 82%"></span>
          <span style="--level: 56%"></span>
          <span style="--level: 68%"></span>
          <span style="--level: 34%"></span>
        </div>

        <div class="signal-tape-copy">
          <span>弱信号 / 城市边缘</span>
          <p>把雨声、远处窗口和低频噪点压成一条安静的过渡轨，让页面从天台场景慢慢落回内容。</p>
        </div>

        <div class="signal-tape-grid">
          {stationSignals.map((signal) => (
            <div class="signal-tape-card">
              <span>{signal.label}</span>
              <strong>{signal.value}</strong>
              <p>{signal.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section
      id="broadcast"
      class="city-broadcast"
      aria-labelledby="city-broadcast-title"
      data-ambient-section
      data-ambient-tone="broadcast"
      data-ambient-channel="CITY / BROADCAST"
      data-ambient-area="旧城频段"
      data-ambient-signal={firstCityBroadcast.signal}
      data-ambient-copy="城市广播接入，雨声里的残片可以重新调频。"
      data-ambient-level={firstCityBroadcast.level}
    >
      <div class="city-broadcast-shell">
        <div class="city-broadcast-copy">
          <p class="section-label">城市广播 / 夜雨残片</p>
          <h2 id="city-broadcast-title">旧城频段里还有一些会被雨水压扁的留言。</h2>
          <p>
            这不是新闻，也不是公告栏。它更像一台忘记关机的楼顶收音机，把末班车、服务井、便利店后门和无人认领的物件压进同一个低保真频道。
          </p>
        </div>

        <div
          class="broadcast-console"
          data-broadcast-console
          data-broadcast-tone={firstCityBroadcast.tone}
          style={`--broadcast-level: ${firstCityBroadcast.level}`}
        >
          <div class="broadcast-status-line">
            <span data-broadcast-channel>{firstCityBroadcast.channel}</span>
            <strong data-broadcast-signal>{firstCityBroadcast.signal}</strong>
          </div>

          <div class="broadcast-body" id="city-broadcast-copy" aria-live="polite">
            <small data-broadcast-time>{firstCityBroadcast.time} / {firstCityBroadcast.code}</small>
            <strong data-broadcast-title>{firstCityBroadcast.title}</strong>
            <p data-broadcast-body>{firstCityBroadcast.body}</p>
          </div>

          <div class="broadcast-meter" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="broadcast-detail">
            <span>接收备注</span>
            <p data-broadcast-detail>{firstCityBroadcast.detail}</p>
          </div>

          <div class="broadcast-actions">
            <button type="button" data-broadcast-retune aria-controls="city-broadcast-copy">
              重新调频
            </button>

            <div class="broadcast-channel-list" aria-label="广播频道选择">
              {cityBroadcasts.map((broadcast, index) => (
                <button
                  type="button"
                  data-broadcast-option
                  data-broadcast-index={String(index)}
                  data-broadcast-channel={broadcast.channel}
                  data-broadcast-time={broadcast.time}
                  data-broadcast-code={broadcast.code}
                  data-broadcast-title={broadcast.title}
                  data-broadcast-signal={broadcast.signal}
                  data-broadcast-body={broadcast.body}
                  data-broadcast-detail={broadcast.detail}
                  data-broadcast-tone={broadcast.tone}
                  data-broadcast-level={broadcast.level}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span>{broadcast.code}</span>
                  <small>{broadcast.title}</small>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <aside class="ambient-channel-strip" data-ambient-readout aria-label="当前滚动频道">
      <div class="ambient-channel-inner">
        <div class="ambient-channel-meter" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="ambient-channel-main">
          <span>SCROLL CHANNEL</span>
          <strong data-ambient-channel-output>ROOF / RAIN</strong>
          <p data-ambient-copy-output aria-live="off">雨声压低了频道，屋顶天线保持在线。</p>
        </div>
        <div class="ambient-channel-readouts" aria-label="当前频道参数">
          <span>
            <small>AREA</small>
            <b data-ambient-area-output>旧楼天台</b>
          </span>
          <span>
            <small>SIGNAL</small>
            <b data-ambient-signal-output>-72 dB</b>
          </span>
        </div>
      </div>
    </aside>

    <section
      id="about"
      class="content-section about-section"
      aria-label="宣言"
      data-ambient-section

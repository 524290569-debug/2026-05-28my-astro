<script>
  const pageShell = document.querySelector("[data-page-signal]");
  const ambientReadout = document.querySelector("[data-ambient-readout]");
  const broadcastConsole = document.querySelector("[data-broadcast-console]");

  if (broadcastConsole) {
    const broadcastOptions = Array.from(broadcastConsole.querySelectorAll("[data-broadcast-option]"));
    const retuneButton = broadcastConsole.querySelector("[data-broadcast-retune]");
    const channelOutput = broadcastConsole.querySelector("[data-broadcast-channel]");
    const signalOutput = broadcastConsole.querySelector("[data-broadcast-signal]");
    const timeOutput = broadcastConsole.querySelector("[data-broadcast-time]");
    const titleOutput = broadcastConsole.querySelector("[data-broadcast-title]");
    const bodyOutput = broadcastConsole.querySelector("[data-broadcast-body]");
    const detailOutput = broadcastConsole.querySelector("[data-broadcast-detail]");

    const setBroadcastState = (button) => {
      if (!button) {
        return;
      }

      const index = Number(button.dataset.broadcastIndex || "0");
      broadcastConsole.dataset.broadcastIndex = String(index);
      broadcastConsole.dataset.broadcastTone = button.dataset.broadcastTone || "rain";
      broadcastConsole.style.setProperty("--broadcast-level", button.dataset.broadcastLevel || "64%");

      if (channelOutput) {
        channelOutput.textContent = button.dataset.broadcastChannel || "";
      }

      if (signalOutput) {
        signalOutput.textContent = button.dataset.broadcastSignal || "";
      }

      if (timeOutput) {
        timeOutput.textContent = `${button.dataset.broadcastTime || ""} / ${button.dataset.broadcastCode || ""}`;
      }

      if (titleOutput) {
        titleOutput.textContent = button.dataset.broadcastTitle || "";
      }

      if (bodyOutput) {
        bodyOutput.textContent = button.dataset.broadcastBody || "";
      }

      if (detailOutput) {
        detailOutput.textContent = button.dataset.broadcastDetail || "";
      }

      broadcastOptions.forEach((item) => {
        item.setAttribute("aria-pressed", item === button ? "true" : "false");
      });
    };

    broadcastOptions.forEach((button) => {
      button.addEventListener("click", () => {
        setBroadcastState(button);
      });
    });

    retuneButton?.addEventListener("click", () => {
      const currentIndex = Number(broadcastConsole.dataset.broadcastIndex || "0");
      const nextButton = broadcastOptions[(currentIndex + 1) % broadcastOptions.length];
      setBroadcastState(nextButton);
    });

    setBroadcastState(
      broadcastOptions.find((button) => button.getAttribute("aria-pressed") === "true")
        || broadcastOptions[0]
    );
  }

  if (pageShell && ambientReadout) {
    const ambientSections = Array.from(document.querySelectorAll("[data-ambient-section]"));
    const ambientChannel = ambientReadout.querySelector("[data-ambient-channel-output]");
    const ambientArea = ambientReadout.querySelector("[data-ambient-area-output]");
    const ambientSignal = ambientReadout.querySelector("[data-ambient-signal-output]");
    const ambientCopy = ambientReadout.querySelector("[data-ambient-copy-output]");
    let activeAmbientId = "";
    let ambientFrame = 0;
    let ambientObserver: IntersectionObserver | null = null;
    let ambientResizeObserver: ResizeObserver | null = null;
    let lastAmbientOffset = "";

    const syncAmbientOffset = () => {
      const height = Math.ceil(ambientReadout.getBoundingClientRect().height);
      const nextOffset = height > 0 ? `${height}px` : "";

      if (nextOffset && nextOffset !== lastAmbientOffset) {
        document.documentElement.style.setProperty("--anchor-offset", nextOffset);
        lastAmbientOffset = nextOffset;
      }
    };

    const setAmbientState = (section) => {
      if (!section || activeAmbientId === section.id) {
        return;
      }

      activeAmbientId = section.id;
      pageShell.dataset.ambientTone = section.dataset.ambientTone || "home";
      ambientReadout.style.setProperty("--ambient-meter", section.dataset.ambientLevel || "72%");

      if (ambientChannel) {
        ambientChannel.textContent = section.dataset.ambientChannel || "ROOF / RAIN";
      }

      if (ambientArea) {
        ambientArea.textContent = section.dataset.ambientArea || "旧楼天台";
      }

      if (ambientSignal) {
        ambientSignal.textContent = section.dataset.ambientSignal || "-72 dB";
      }

      if (ambientCopy) {
        ambientCopy.textContent = section.dataset.ambientCopy || "雨声压低了频道，屋顶天线保持在线。";
      }
    };

    const pickAmbientSection = () => {
      syncAmbientOffset();

      const anchorY = window.innerHeight * 0.42;
      const visibleSections = ambientSections
        .map((section) => {
          const rect = section.getBoundingClientRect();
          const visible = rect.bottom > 0 && rect.top < window.innerHeight;

          return {
            section,
            distance: Math.abs(rect.top - anchorY),
            visible
          };
        })
        .filter((item) => item.visible)
        .sort((a, b) => a.distance - b.distance);

      setAmbientState(visibleSections[0]?.section || ambientSections[0]);
    };

    const scheduleAmbientRefresh = () => {
      if (ambientFrame) {
        return;
      }

      ambientFrame = window.requestAnimationFrame(() => {
        ambientFrame = 0;
        pickAmbientSection();
      });
    };

    const realignHashTarget = () => {
      const hashId = window.location.hash
        ? decodeURIComponent(window.location.hash.slice(1))
        : "";
      const target = hashId ? document.getElementById(hashId) : null;

      if (target?.matches(".content-section, .city-broadcast")) {
        target.scrollIntoView({ block: "start", behavior: "auto" });
      }
    };

    if (ambientSections.length) {
      setAmbientState(ambientSections[0]);
      syncAmbientOffset();

      if ("IntersectionObserver" in window) {
        ambientObserver = new IntersectionObserver(scheduleAmbientRefresh, {
          rootMargin: "-38% 0px -38% 0px",
          threshold: [0, 0.01]
        });

        ambientSections.forEach((section) => {
          ambientObserver.observe(section);
        });

        window.__grayRainAmbientObserver = ambientObserver;
      } else {
        window.addEventListener("scroll", scheduleAmbientRefresh, { passive: true });
      }

      if ("ResizeObserver" in window) {
        ambientResizeObserver = new ResizeObserver(scheduleAmbientRefresh);
        ambientResizeObserver.observe(ambientReadout);
      }

      window.addEventListener("resize", scheduleAmbientRefresh, { passive: true });
      window.addEventListener("orientationchange", scheduleAmbientRefresh, { passive: true });
      window.addEventListener("pageshow", scheduleAmbientRefresh, { passive: true });
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) {
          scheduleAmbientRefresh();
        }
      });

      window.setTimeout(() => {
        pickAmbientSection();
        realignHashTarget();
      }, 120);

      window.addEventListener("beforeunload", () => {
        if (ambientFrame) {
          window.cancelAnimationFrame(ambientFrame);
        }

        ambientObserver?.disconnect();
        ambientResizeObserver?.disconnect();
      });
    }
  }

  const sceneDiscovery = document.querySelector("[data-scene-discovery]");
  const sceneStatus = document.querySelector("[data-scene-discovery-status]");

  if (sceneDiscovery && sceneStatus) {
    const hotspotButtons = Array.from(sceneDiscovery.querySelectorAll("[data-hotspot-button]"));
    const foundCount = sceneStatus.querySelector("[data-scene-found-count]");
    const statusText = sceneStatus.querySelector("[data-scene-status-text]");
    const totalHotspots = Number(sceneStatus.dataset.totalHotspots || hotspotButtons.length);
    const foundHotspots = new Set();

    const updateDiscoveryStatus = () => {
      const count = foundHotspots.size;

      if (foundCount) {
        foundCount.textContent = String(count);
      }

      sceneStatus.setAttribute("aria-label", `现场碎片发现进度：${count} / ${totalHotspots}`);

      if (statusText) {
        statusText.textContent =
          count === totalHotspots
            ? "三段现场记录已接入，噪声保持在低位。"
            : "点击图中的弱信号点，读取现场记录。";
      }
    };

    const closeSceneCard = (card) => {
      const panel = card.querySelector("[data-hotspot-panel]");

      if (panel) {
        panel.hidden = true;
      }

      card.querySelectorAll("[data-hotspot-button]").forEach((button) => {
        button.setAttribute("aria-expanded", "false");
        button.removeAttribute("data-active");
      });
    };

    const openHotspot = (button) => {
      const card = button.closest("[data-scene-card]");

      if (!card) {
        return;
      }

      const panel = card.querySelector("[data-hotspot-panel]");
      const code = panel?.querySelector("[data-hotspot-panel-code]");
      const title = panel?.querySelector("[data-hotspot-panel-title]");
      const body = panel?.querySelector("[data-hotspot-panel-body]");
      const isSameOpenHotspot = button.hasAttribute("data-active") && !panel?.hidden;

      if (isSameOpenHotspot) {
        closeSceneCard(card);
        return;
      }

      card.querySelectorAll("[data-hotspot-button]").forEach((item) => {
        const isActive = item === button;

        item.setAttribute("aria-expanded", isActive ? "true" : "false");
        item.toggleAttribute("data-active", isActive);
      });

      if (panel) {
        panel.hidden = false;
      }

      if (code) {
        code.textContent = button.dataset.hotspotCode || "";
      }

      if (title) {
        title.textContent = button.dataset.hotspotTitle || "";
      }

      if (body) {
        body.textContent = button.dataset.hotspotBody || "";
      }

      if (button.dataset.hotspotId) {
        foundHotspots.add(button.dataset.hotspotId);
        updateDiscoveryStatus();
      }
    };

    hotspotButtons.forEach((button) => {
      button.addEventListener("click", () => {
        openHotspot(button);
      });

      button.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") {
          return;
        }

        event.preventDefault();
        openHotspot(button);
      });
    });

    sceneDiscovery.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") {
        return;
      }

      const card = event.target instanceof Element
        ? event.target.closest("[data-scene-card]")
        : null;

      if (card) {
        closeSceneCard(card);
      }
    });

    updateDiscoveryStatus();
  }

  const archivePanel = document.querySelector("[data-archive-panel]");

  if (archivePanel) {
    const filterButtons = Array.from(archivePanel.querySelectorAll("[data-archive-filter]"));
    const archiveEntries = Array.from(archivePanel.querySelectorAll("[data-archive-entry]"));
    const filterStatus = archivePanel.querySelector("[data-archive-filter-status]");
    const deskCard = document.querySelector("[data-archive-desk-card]");
    const deskChannel = document.querySelector("[data-archive-desk-channel]");
    const deskTitle = document.querySelector("[data-archive-desk-title]");
    const deskDetail = document.querySelector("[data-archive-desk-detail]");
    const deskMeter = document.querySelector("[data-archive-desk-meter]");

    const setDeskReadout = (source) => {
      if (deskCard && source.dataset.archiveTone) {
        deskCard.dataset.archiveTone = source.dataset.archiveTone;
      }

      if (deskChannel) {
        deskChannel.textContent = source.dataset.archiveStatus || "ARCHIVE / ALL";
      }

      if (deskTitle) {
        deskTitle.textContent = source.dataset.archiveTitle || "夜间工作台";
      }

      if (deskDetail) {
        deskDetail.textContent = source.dataset.archiveDetail || "记录已接入，等待筛选。";
      }

      if (deskMeter) {
        deskMeter.style.setProperty("--level", source.dataset.archiveLevel || "76%");
      }
    };

    const syncEntrySummary = (entry) => {
      const summary = entry.querySelector("[data-archive-summary]");

      if (summary) {
        summary.setAttribute("aria-expanded", entry.open ? "true" : "false");
      }
    };

    const closeEntry = (entry) => {
      entry.open = false;
      syncEntrySummary(entry);
    };

    const setFilter = (button) => {
      const category = button.dataset.archiveFilter || "all";
      const label = button.dataset.archiveFilterLabel || "全部";
      let visibleCount = 0;

      filterButtons.forEach((item) => {
        item.setAttribute("aria-pressed", item === button ? "true" : "false");
      });

      archiveEntries.forEach((entry) => {
        const shouldShow = category === "all" || entry.dataset.category === category;

        entry.hidden = !shouldShow;

        if (shouldShow) {
          visibleCount += 1;
        } else {
          closeEntry(entry);
        }
      });

      if (filterStatus) {
        filterStatus.textContent = `${label}频道 ${visibleCount} 条记录接入。`;
      }

      setDeskReadout(button);
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setFilter(button);
      });
    });

    archiveEntries.forEach((entry) => {
      entry.addEventListener("toggle", () => {
        syncEntrySummary(entry);

        if (!entry.open) {
          return;
        }

        archiveEntries.forEach((item) => {
          if (item !== entry && !item.hidden) {
            closeEntry(item);
          }
        });

        setDeskReadout(entry);
      });
    });

    archivePanel.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") {
        return;
      }

      const openEntry = archiveEntries.find((entry) => entry.open && !entry.hidden);

      if (!openEntry) {
        return;
      }

      closeEntry(openEntry);

      const summary = openEntry.querySelector("[data-archive-summary]");

      if (summary) {
        summary.focus();
      }
    });

    const initialFilter = filterButtons.find(
      (button) => button.getAttribute("aria-pressed") === "true"
    );

    if (initialFilter) {
      setFilter(initialFilter);
    }
  }

  const contactPanel = document.querySelector("[data-contact-panel]");

  if (contactPanel) {
    const contactLinks = Array.from(contactPanel.querySelectorAll("[data-contact-link]"));
    const contactStatus = contactPanel.querySelector("[data-contact-status-output]");
    const contactCopy = contactPanel.querySelector("[data-contact-copy]");
    const transmissionRows = Array.from(contactPanel.querySelectorAll("[data-contact-row]"));

    const defaultContactState = {
      tone: contactPanel.dataset.contactTone || "standby",
      status: contactStatus?.textContent?.trim() || "STANDBY / CONTACT",
      log: contactCopy?.textContent?.trim() || "",
      signals: transmissionRows.map((row) => ({
        label: row.querySelector("[data-contact-row-label]")?.textContent?.trim() || "",
        value: row.querySelector("[data-contact-row-value]")?.textContent?.trim() || "",
        detail: row.querySelector("[data-contact-row-detail]")?.textContent?.trim() || "",
        level: row.style.getPropertyValue("--level") || "50%"
      }))
    };

    const parseContactSignals = (link) => {
      try {
        const signals = JSON.parse(link.dataset.contactSignals || "[]");

        return Array.isArray(signals) ? signals : [];
      } catch {
        return [];
      }
    };

    const getContactState = (link) => ({
      tone: link.dataset.contactTone || "standby",
      status: link.dataset.contactStatus || defaultContactState.status,
      log: link.dataset.contactLog || defaultContactState.log,
      signals: parseContactSignals(link)
    });

    const setContactState = (state, activeLink = null) => {
      contactPanel.dataset.contactTone = state.tone || "standby";

      if (contactStatus) {
        contactStatus.textContent = state.status || defaultContactState.status;
      }

      if (contactCopy) {
        contactCopy.textContent = state.log || defaultContactState.log;
      }

      transmissionRows.forEach((row, index) => {
        const signal = state.signals[index] || defaultContactState.signals[index];

        if (!signal) {
          return;
        }

        const label = row.querySelector("[data-contact-row-label]");
        const value = row.querySelector("[data-contact-row-value]");
        const detail = row.querySelector("[data-contact-row-detail]");

        if (label) {
          label.textContent = signal.label || "";
        }

        if (value) {
          value.textContent = signal.value || "";
        }

        if (detail) {
          detail.textContent = signal.detail || "";
        }

        row.style.setProperty("--level", signal.level || "50%");
      });

      contactLinks.forEach((link) => {
        link.toggleAttribute("data-contact-active", link === activeLink);
      });
    };

    contactLinks.forEach((link) => {
      const updateContactState = () => {
        setContactState(getContactState(link), link);
      };

      link.addEventListener("pointerenter", updateContactState);
      link.addEventListener("pointerdown", updateContactState, { passive: true });
      link.addEventListener("focus", updateContactState);
      link.addEventListener("click", updateContactState);
    });

    contactPanel.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") {
        return;
      }

      setContactState(defaultContactState);
    });
  }

  const keyboardRouter = document.querySelector("[data-keyboard-router]");

  if (keyboardRouter) {
    const routerToggle = keyboardRouter.querySelector("[data-shortcut-trigger]");
    const routerPanel = keyboardRouter.querySelector("[data-shortcut-panel]");
    const routerClose = keyboardRouter.querySelector("[data-shortcut-close]");
    const routerStatus = keyboardRouter.querySelector("[data-shortcut-status]");
    const shortcutLinks = Array.from(keyboardRouter.querySelectorAll("[data-shortcut-jump]"));
    const routeFocusTargets = {
      home: "[data-channel-option]",
      works: "[data-hotspot-button]",
      blog: "[data-archive-filter]",
      contact: "[data-contact-link]"
    };
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const setRouterStatus = (message) => {
      if (routerStatus) {
        routerStatus.textContent = message;
      }
    };

    const setRouterOpen = (isOpen, shouldFocus = false) => {
      if (!routerPanel || !routerToggle) {
        return;
      }

      routerPanel.hidden = !isOpen;
      routerToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      keyboardRouter.toggleAttribute("data-router-open", isOpen);

      if (isOpen) {
        setRouterStatus("路由面板已接入，选择一个频道。");
      }

      if (shouldFocus) {
        (isOpen ? shortcutLinks[0] : routerToggle)?.focus();
      }
    };

    const isEditableTarget = (target) =>
      target instanceof Element
      && Boolean(target.closest("input, textarea, select, [contenteditable='true']"));

    const closeScenePanels = () => {
      document.querySelectorAll("[data-scene-card]").forEach((card) => {
        const panel = card.querySelector("[data-hotspot-panel]");

        if (panel) {
          panel.hidden = true;
        }

        card.querySelectorAll("[data-hotspot-button]").forEach((button) => {
          button.setAttribute("aria-expanded", "false");
          button.removeAttribute("data-active");
        });
      });
    };

    const closeArchiveEntries = () => {
      document.querySelectorAll("[data-archive-entry]").forEach((entry) => {
        entry.open = false;

        const summary = entry.querySelector("[data-archive-summary]");

        if (summary) {
          summary.setAttribute("aria-expanded", "false");
        }
      });
    };

    const closeOpenInteractionPanels = () => {
      closeScenePanels();
      closeArchiveEntries();
      setRouterOpen(false);
      setRouterStatus("已收束现场热点与档案日志。");
    };

    const focusRoute = (id) => {
      const section = document.getElementById(id);

      if (!section) {
        return;
      }

      const focusTarget = section.querySelector(routeFocusTargets[id] || "a, button, summary")
        || section;

      section.scrollIntoView({
        block: "start",
        behavior: reduceMotion.matches ? "auto" : "smooth"
      });

      if (!focusTarget.hasAttribute("tabindex") && focusTarget === section) {
        focusTarget.setAttribute("tabindex", "-1");
      }

      window.setTimeout(() => {
        focusTarget.focus({ preventScroll: true });
      }, reduceMotion.matches ? 0 : 220);

      const label = shortcutLinks.find((link) => link.dataset.shortcutJump === id)
        ?.querySelector("span")
        ?.textContent
        ?.trim();

      setRouterStatus(`${label || "目标"}频道已定位。`);
    };

    routerToggle?.addEventListener("click", () => {
      setRouterOpen(routerPanel?.hidden ?? true, true);
    });

    routerClose?.addEventListener("click", () => {
      closeOpenInteractionPanels();
      routerToggle?.focus();
    });

    shortcutLinks.forEach((link) => {
      link.addEventListener("click", () => {
        setRouterOpen(false);
        focusRoute(link.dataset.shortcutJump || "");
      });
    });

    document.addEventListener("keydown", (event) => {
      if (isEditableTarget(event.target)) {
        return;
      }

      if (event.key === "Escape") {
        closeOpenInteractionPanels();
        return;
      }

      if (event.key === "?" && !event.altKey && !event.ctrlKey && !event.metaKey) {
        event.preventDefault();
        setRouterOpen(routerPanel?.hidden ?? true, true);
        return;
      }

      if (!event.altKey || event.ctrlKey || event.metaKey || event.shiftKey) {
        return;
      }

      const routeByKey = {
        "1": "home",
        "2": "works",
        "3": "blog",
        "4": "contact"
      };
      const route = routeByKey[event.key];

      if (!route) {
        return;
      }

      event.preventDefault();
      setRouterOpen(false);
      focusRoute(route);
    });
  }
</script>

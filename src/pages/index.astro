---
import BaseLayout from "../layouts/BaseLayout.astro";
import CyberpunkHero from "../components/CyberpunkHero.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path) => `${basePath}${path}`;

const workImages = [
  {
    src: assetPath("assets/works/postpunk-rooftop.webp"),
    width: 1280,
    height: 720,
    title: "屋顶回声",
    meta: "雨幕 / 天线 / 低频",
    signal: {
      code: "ANT-03",
      value: "82%",
      label: "天线余响"
    },
    hotspots: [
      {
        code: "R-1",
        title: "天线背风面",
        body: "雨线在这里变细，像有人把频段往低处拧了一格。",
        x: 68,
        y: 26
      },
      {
        code: "R-2",
        title: "屋顶积水",
        body: "低频反射停在水面上，远城灯光只剩一点蓝灰。",
        x: 38,
        y: 56
      }
    ]
  },
  {
    src: assetPath("assets/works/postpunk-passage.webp"),
    width: 1280,
    height: 720,
    title: "地下通道",
    meta: "湿瓷砖 / 合成器 / 断讯",
    signal: {
      code: "SUB-11",
      value: "-6 dB",
      label: "通道底噪"
    },
    hotspots: [
      {
        code: "S-1",
        title: "灯管残响",
        body: "白光被瓷砖拆成碎片，通道里只剩轻微电流声。",
        x: 72,
        y: 30
      },
      {
        code: "S-2",
        title: "断讯边界",
        body: "信号到这里开始掉帧，脚步声比频道更清楚。",
        x: 43,
        y: 55
      }
    ]
  },
  {
    src: assetPath("assets/works/postpunk-bridge.webp"),
    width: 1280,
    height: 720,
    title: "高架余光",
    meta: "远城 / 铁轨 / 冷蓝反射",
    signal: {
      code: "TRK-07",
      value: "41%",
      label: "远城反射"
    },
    hotspots: [
      {
        code: "B-1",
        title: "高架余光",
        body: "车流被雨雾削平，亮度没有上来，轮廓还在。",
        x: 62,
        y: 28
      },
      {
        code: "B-2",
        title: "轨道低线",
        body: "冷蓝反射贴着铁轨滑走，像一条快要断开的信号线。",
        x: 30,
        y: 52
      }
    ]
  }
];

const sceneHotspotTotal = workImages.reduce(
  (total, image) => total + image.hotspots.length,
  0
);

const fieldNotes = [
  {
    code: "POST",
    title: "内向节拍",
    body: "后朋克的线索不放在口号里，而放在重复、空隙和一点点不稳定的灯光里。"
  },
  {
    code: "LOFI",
    title: "保留噪点",
    body: "页面不把痕迹擦干净：雨纹、低对比颗粒和暗处反光负责把空间留住。"
  },
  {
    code: "IND",
    title: "机械低频",
    body: "工业音乐的硬边被压成细线、刻度和信号条，只留下冷硬的节奏感。"
  },
  {
    code: "EDGE",
    title: "城市边缘",
    body: "赛博末世感来自远处技术城市和近处旧屋顶之间的距离，不靠高饱和霓虹硬撑。"
  }
];

const readingSources = [
  {
    code: "POST",
    title: "后朋克",
    body: "把朋克之后的实验性和内向感，压进重复、空隙和冷光节奏里。",
    href: "https://www.britannica.com/art/postpunk"
  },
  {
    code: "LOFI",
    title: "低保真",
    body: "保留底噪、失真和不完美，让页面材质像旧录音一样可触摸。",
    href: "https://www.britannica.com/art/lo-fi-music"
  },
  {
    code: "IND",
    title: "工业音乐",
    body: "用噪声、机械节拍和磁带循环感，给界面留下一层硬边。",
    href: "https://www.britannica.com/art/industrial-music"
  },
  {
    code: "CYBER",
    title: "赛博朋克",
    body: "只取高技术城市和边缘个体之间的冷距离，不把霓虹推到过载。",
    href: "https://www.britannica.com/art/cyberpunk"
  }
];

const stationSignals = [
  {
    label: "SIGNAL",
    value: "-72 dB",
    detail: "远城残响稳定"
  },
  {
    label: "RAIN",
    value: "18 mm",
    detail: "屋顶反射低亮"
  },
  {
    label: "NOISE",
    value: "04%",
    detail: "磁带底噪不过载"
  }
];

const contactRoutes = [
  {
    label: "发送邮件",
    meta: "MAIL / DIRECT",
    href: "mailto:hello@example.com"
  },
  {
    label: "查看 GitHub",
    meta: "REPO / PUBLIC",
    href: "https://github.com/524290569-debug",
    external: true
  },
  {
    label: "返回顶部",
    meta: "HOME / SIGNAL",
    href: "#home"
  }
];

const transmissionSignals = [
  {
    label: "CHANNEL",
    value: "OPEN",
    detail: "弱信号入口保持在线",
    level: "82%"
  },
  {
    label: "LATENCY",
    value: "03 ms",
    detail: "低频回声轻微延迟",
    level: "54%"
  },
  {
    label: "WINDOW",
    value: "LOW",
    detail: "只保留一格暖黄窗光",
    level: "38%"
  }
];

const archivePosts = [
  {
    date: "2026-06-05",
    displayDate: "2026.06.05",
    tag: "视觉",
    title: "雨夜界面不能只靠黑色",
    body: "真正有层次的暗色页面，需要雾、反光、低对比纹理和非常节制的霓虹点缀。",
    signal: {
      label: "LIGHT",
      value: "18%",
      detail: "窗光低亮",
      level: "18%"
    }
  },
  {
    date: "2026-06-04",
    displayDate: "2026.06.04",
    tag: "交互",
    title: "动效应该像远处的灯",
    body: "它可以存在，但不能抢走阅读和停留。视差、微光、信号条都应该在鼠标离开后安静下来。",
    signal: {
      label: "MOTION",
      value: "24%",
      detail: "低频微动",
      level: "24%"
    }
  },
  {
    date: "2026-06-03",
    displayDate: "2026.06.03",
    tag: "声音",
    title: "低保真不是粗糙，而是保留痕迹",
    body: "像磁带底噪、旧墙雨痕和未清理干净的反射，它们让页面从模板里脱离出来。",
    signal: {
      label: "NOISE",
      value: "41%",
      detail: "底噪保留",
      level: "41%"
    }
  }
];

const textureImage = assetPath("assets/textures/rain-wall.webp");
const deskImage = assetPath("assets/features/postpunk-desk.webp");
const deskImageSize = { width: 1200, height: 900 };
---

<BaseLayout
  title="灰雨电台 - 雨夜后朋克个人站"
  description="一个后朋克、雨夜城市、低保真视觉与前端实验交织的个人网站。"
  preloadImages={[
    { href: "assets/hero/sky-v5.webp", type: "image/webp" },
    { href: "assets/hero/city-v5.webp", type: "image/webp", fetchPriority: "high" },
    { href: "assets/hero/rooftop-v5.webp", type: "image/webp" }
  ]}
>
  <main class="page-shell page-shell-visual" style={`--rain-wall: url("${textureImage}")`}>
    <CyberpunkHero />

    <section class="surface-brief" aria-label="频道状态">
      <div class="brief-track">
        <div>
          <span>频率</span>
          <strong>03:17 / 冷雨在线</strong>
        </div>
        <div>
          <span>位置</span>
          <strong>旧楼天台 / 北向窗</strong>
        </div>
        <div>
          <span>声场</span>
          <strong>后朋克 / 低保真 / 工业噪声</strong>
        </div>
        <div>
          <span>状态</span>
          <strong>低亮度维护中</strong>
        </div>
      </div>
    </section>

    <section class="signal-tape" aria-label="弱信号层">
      <div class="signal-tape-inner">
        <div class="signal-tape-meter" aria-hidden="true">
          <span style="--level: 82%"></span>
          <span style="--level: 56%"></span>
          <span style="--level: 68%"></span>
          <span style="--level: 34%"></span>
        </div>

        <div class="signal-tape-copy">
          <span>弱信号 / 城市边缘</span>
          <p>把雨声、远处窗口和低频噪点压成一条安静的过渡轨，让页面从天台场景慢慢落回内容。</p>
        </div>

        <div class="signal-tape-grid">
          {stationSignals.map((signal) => (
            <div class="signal-tape-card">
              <span>{signal.label}</span>
              <strong>{signal.value}</strong>
              <p>{signal.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="content-section about-section" aria-label="宣言">
      <div class="section-shell about-grid">
        <div class="section-copy">
          <p class="section-label">宣言 / 低保真夜航</p>
          <h2>把潮湿、失真和城市边缘感整理成可以停留的界面。</h2>
          <p>
            灰雨电台是一个个人站点实验：它借用后朋克的内省和实验性，保留低保真的噪点、雨痕与旧设备质感，再把这些东西压进一个安静的网页界面里。
          </p>
          <p>
            它不追求明亮、完整和商业感。更重要的是夜晚的节奏、远处窗光、楼顶管线、过曝之前的霓虹，以及一个人继续写代码时听见的城市底噪。
          </p>

          <div class="process-strip" aria-label="创作流程">
            <span>采样</span>
            <span>降噪</span>
            <span>成像</span>
          </div>

          <div class="tool-cloud" aria-label="风格标签">
            <span>后朋克</span>
            <span>雨夜屋顶</span>
            <span>冷色城市</span>
            <span>低保真纹理</span>
            <span>轻量交互</span>
          </div>
        </div>

        <aside class="profile-stack" aria-label="视觉参数">
          <div class="profile-visual profile-visual-active" aria-hidden="true">
            <span class="profile-core"></span>
            <span class="profile-ring profile-ring-a"></span>
            <span class="profile-ring profile-ring-b"></span>
            <span class="field-dial"></span>
          </div>

          <div class="signal-panel">
            <div class="signal-row">
              <span>色温</span>
              <strong>蓝黑 / 雾灰 / 暗紫</strong>
            </div>
            <div class="signal-row">
              <span>节拍</span>
              <strong>缓慢 / 重复 / 克制</strong>
            </div>
            <div class="signal-row">
              <span>材质</span>
              <strong>雨痕 / 玻璃 / 旧海报</strong>
            </div>
            <div class="signal-row">
              <span>交互</span>
              <strong>视差 / 微光 / 轻动画</strong>
            </div>
          </div>

          <div class="availability-card">
            <span>本轮目标</span>
            <strong>让页面从氛围海报变成可持续扩展的个人作品入口。</strong>
          </div>
        </aside>
      </div>
    </section>

    <section id="works" class="content-section works-section image-section" aria-label="现场">
      <div class="section-shell">
        <div class="section-heading">
          <p class="section-label">现场 / 三段夜间切片</p>
          <h2>不是作品集陈列，而是三段从城市边缘截取的低光现场。</h2>
        </div>

        <div
          class="scene-discovery-status"
          aria-label={`现场碎片发现进度：0 / ${sceneHotspotTotal}`}
          data-scene-discovery-status
          data-total-hotspots={sceneHotspotTotal}
        >
          <span>已发现碎片</span>
          <strong><b data-scene-found-count>0</b> / {sceneHotspotTotal}</strong>
          <p data-scene-status-text>点击图中的弱信号点，读取现场记录。</p>
        </div>

        <div class="image-stage-grid" data-scene-discovery>
          {workImages.map((image, index) => (
            <figure class={`work-image-card work-image-card-${index + 1}`} data-scene-card>
              <img
                src={image.src}
                alt={image.title}
                width={image.width}
                height={image.height}
                loading="lazy"
                decoding="async"
                sizes={index === 0
                  ? "(max-width: 720px) calc(100vw - 2rem), (max-width: 980px) 50vw, 54vw"
                  : "(max-width: 720px) calc(100vw - 2rem), (max-width: 980px) 50vw, 34vw"}
              />
              <div class="work-image-readout" aria-label={`${image.signal.label}：${image.signal.value}`}>
                <span>{image.signal.code}</span>
                <strong>{image.signal.value}</strong>
                <small>{image.signal.label}</small>
              </div>
              <div class="scene-hotspot-layer" aria-label={`${image.title}现场热点`}>
                {image.hotspots.map((hotspot, hotspotIndex) => {
                  const hotspotId = `${image.signal.code}-${hotspotIndex + 1}`;
                  const noteId = `scene-note-${index + 1}`;

                  return (
                    <button
                      class="scene-hotspot"
                      type="button"
                      style={`--hotspot-x: ${hotspot.x}%; --hotspot-y: ${hotspot.y}%`}
                      data-hotspot-button
                      data-hotspot-id={hotspotId}
                      data-hotspot-code={hotspot.code}
                      data-hotspot-title={hotspot.title}
                      data-hotspot-body={hotspot.body}
                      aria-label={`${image.title}：${hotspot.title}`}
                      aria-controls={noteId}
                      aria-expanded="false"
                    >
                      <span>{hotspot.code}</span>
                    </button>
                  );
                })}
              </div>
              <div
                class="scene-hotspot-panel"
                id={`scene-note-${index + 1}`}
                data-hotspot-panel
                aria-live="polite"
                hidden
              >
                <span data-hotspot-panel-code></span>
                <strong data-hotspot-panel-title></strong>
                <p data-hotspot-panel-body></p>
              </div>
              <figcaption>
                <strong>{image.title}</strong>
                <span>{image.meta}</span>
              </figcaption>
              <noscript>
                <div class="scene-hotspot-noscript">
                  {image.hotspots.map((hotspot) => (
                    <p>
                      <strong>{hotspot.code} / {hotspot.title}</strong>
                      <span>{hotspot.body}</span>
                    </p>
                  ))}
                </div>
              </noscript>
            </figure>
          ))}
        </div>

        <div class="works-note">
          <span>展示逻辑</span>
          <p>
            当前页面先用图片建立空间感，再用少量文字补足叙事。后续可以把这里扩展成项目、摄影、文章或交互实验的入口。
          </p>
        </div>
      </div>
    </section>

    <section id="blog" class="content-section blog-section archive-section" aria-label="档案">
      <div class="section-shell blog-layout">
        <div class="blog-copy-column">
          <div class="section-heading">
            <p class="section-label">档案 / 桌面电台</p>
            <h2>把资料、笔记和界面实验放进同一个夜间工作台。</h2>
          </div>

          <div class="post-list">
            {archivePosts.map((post) => (
              <article class="post-row">
                <time datetime={post.date}>{post.displayDate}</time>
                <div>
                  <p class="post-tag">{post.tag}</p>
                  <h3>{post.title}</h3>
                  <p>{post.body}</p>
                  <div
                    class="post-signal-strip"
                    style={`--level: ${post.signal.level}`}
                    aria-label={`${post.signal.label}：${post.signal.value}，${post.signal.detail}`}
                  >
                    <span>{post.signal.label}</span>
                    <i aria-hidden="true"></i>
                    <strong>{post.signal.value}</strong>
                    <small>{post.signal.detail}</small>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="blog-media-column">
          <div class="feature-photo-card">
            <img
              src={deskImage}
              alt="雨夜窗边的合成器、磁带机和耳机"
              width={deskImageSize.width}
              height={deskImageSize.height}
              loading="lazy"
              decoding="async"
              sizes="(max-width: 980px) calc(100vw - 2rem), 44vw"
            />
            <div class="sound-bars" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>

        <div class="field-note-grid" aria-label="夜间采样记录">
          {fieldNotes.map((note) => (
            <article class="field-note">
              <span>{note.code}</span>
              <h3>{note.title}</h3>
              <p>{note.body}</p>
            </article>
          ))}
        </div>

        <aside class="reading-card" aria-label="资料来源">
          <span>资料方向</span>
          <p>
            本轮文案把资料压成页面语气：后朋克保留实验和内省，低保真保留不完美的录音痕迹，工业音乐留下机械节奏，赛博朋克只取技术城市和边缘个体之间的冷距离。
          </p>
          <div class="source-links" aria-label="参考资料链接">
            {readingSources.map((source) => (
              <a href={source.href} target="_blank" rel="noreferrer">
                <small>{source.code}</small>
                <strong>{source.title}</strong>
                <p>{source.body}</p>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section id="contact" class="content-section contact-section" aria-label="联络">
      <div class="section-shell contact-grid">
        <div class="section-copy">
          <p class="section-label">联络 / 弱信号入口</p>
          <h2>如果你也偏爱冷雨、低频和不那么明亮的界面，可以从这里接入。</h2>
          <p>
            这个站点会继续作为个人视觉和前端实验场更新。下一步可以加入作品详情、音乐播放组件、文章页和更完整的移动端体验。
          </p>
        </div>

        <div class="contact-panel" aria-label="弱信号联络面板">
          <div class="contact-link-list" aria-label="联络入口">
            {contactRoutes.map((route) => (
              <a
                href={route.href}
                target={route.external ? "_blank" : undefined}
                rel={route.external ? "noreferrer" : undefined}
              >
                <span>{route.label}</span>
                <small>{route.meta}</small>
              </a>
            ))}
          </div>

          <div class="transmission-log" aria-label="传输状态">
            <div class="transmission-header">
              <span>TRANSMISSION LOG</span>
              <strong>03:17</strong>
            </div>

            {transmissionSignals.map((signal) => (
              <div class="transmission-row" style={`--level: ${signal.level}`}>
                <div>
                  <span>{signal.label}</span>
                  <strong>{signal.value}</strong>
                </div>
                <i aria-hidden="true"></i>
                <p>{signal.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-inner">
        <span>灰雨电台 / 雨声频道</span>
        <span>后朋克界面记录</span>
      </div>
    </footer>
  </main>
</BaseLayout>

<script>
  const sceneDiscovery = document.querySelector("[data-scene-discovery]");
  const sceneStatus = document.querySelector("[data-scene-discovery-status]");

  if (sceneDiscovery && sceneStatus) {
    const hotspotButtons = Array.from(sceneDiscovery.querySelectorAll("[data-hotspot-button]"));
    const foundCount = sceneStatus.querySelector("[data-scene-found-count]");
    const statusText = sceneStatus.querySelector("[data-scene-status-text]");
    const totalHotspots = Number(sceneStatus.dataset.totalHotspots || hotspotButtons.length);
    const foundHotspots = new Set();

    const updateDiscoveryStatus = () => {
      const count = foundHotspots.size;

      if (foundCount) {
        foundCount.textContent = String(count);
      }

      sceneStatus.setAttribute("aria-label", `现场碎片发现进度：${count} / ${totalHotspots}`);

      if (statusText) {
        statusText.textContent =
          count === totalHotspots
            ? "三段现场记录已接入，噪声保持在低位。"
            : "点击图中的弱信号点，读取现场记录。";
      }
    };

    const closeSceneCard = (card) => {
      const panel = card.querySelector("[data-hotspot-panel]");

      if (panel) {
        panel.hidden = true;
      }

      card.querySelectorAll("[data-hotspot-button]").forEach((button) => {
        button.setAttribute("aria-expanded", "false");
        button.removeAttribute("data-active");
      });
    };

    const openHotspot = (button) => {
      const card = button.closest("[data-scene-card]");

      if (!card) {
        return;
      }

      const panel = card.querySelector("[data-hotspot-panel]");
      const code = panel?.querySelector("[data-hotspot-panel-code]");
      const title = panel?.querySelector("[data-hotspot-panel-title]");
      const body = panel?.querySelector("[data-hotspot-panel-body]");

      card.querySelectorAll("[data-hotspot-button]").forEach((item) => {
        const isActive = item === button;

        item.setAttribute("aria-expanded", isActive ? "true" : "false");
        item.toggleAttribute("data-active", isActive);
      });

      if (panel) {
        panel.hidden = false;
      }

      if (code) {
        code.textContent = button.dataset.hotspotCode || "";
      }

      if (title) {
        title.textContent = button.dataset.hotspotTitle || "";
      }

      if (body) {
        body.textContent = button.dataset.hotspotBody || "";
      }

      if (button.dataset.hotspotId) {
        foundHotspots.add(button.dataset.hotspotId);
        updateDiscoveryStatus();
      }
    };

    hotspotButtons.forEach((button) => {
      button.addEventListener("click", () => {
        openHotspot(button);
      });

      button.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") {
          return;
        }

        event.preventDefault();
        openHotspot(button);
      });
    });

    sceneDiscovery.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") {
        return;
      }

      const card = event.target instanceof Element
        ? event.target.closest("[data-scene-card]")
        : null;

      if (card) {
        closeSceneCard(card);
      }
    });

    updateDiscoveryStatus();
  }
</script>

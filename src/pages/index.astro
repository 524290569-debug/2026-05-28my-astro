---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrayRainExperience from "../components/GrayRainExperience.astro";
---

<BaseLayout
  title="灰雨电台｜在城市低频里保持接收"
  description="一座可以调频、探索现场与翻阅夜航日志的后朋克雨夜电台。"
  skipTarget="#station"
  preloadImages={[
    { href: "assets/hero/city-v5.webp", type: "image/webp", fetchPriority: "high" },
    { href: "assets/hero/rooftop-v5.webp", type: "image/webp", fetchPriority: "high" }
  ]}
>
  <GrayRainExperience />
</BaseLayout>

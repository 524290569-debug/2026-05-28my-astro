---
import BaseLayout from "../layouts/BaseLayout.astro";
import CyberpunkHero from "../components/CyberpunkHero.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path) => `${basePath}${path}`;

const workImages = [
  assetPath("assets/works/postpunk-rooftop.webp"),
  assetPath("assets/works/postpunk-passage.webp"),
  assetPath("assets/works/postpunk-bridge.webp")
];
---

<BaseLayout title="灰雨电台" description="雨夜城市个人网站">
  <main class="page-shell page-shell-visual">
    <CyberpunkHero />

    <section class="surface-brief surface-brief-visual" aria-label="状态层">
      <div class="brief-track visual-track" aria-hidden="true">
        {Array.from({ length: 4 }).map(() => (
          <div>
            <i></i>
            <b></b>
          </div>
        ))}
      </div>
    </section>

    <section id="about" class="content-section about-section visual-section" aria-label="第一部分">
      <div class="section-shell about-grid">
        <div class="visual-copy" aria-hidden="true">
          <span class="visual-kicker"></span>
          <span class="visual-title"></span>
          <span class="visual-title visual-title-short"></span>
          <div class="visual-paragraph">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="process-strip process-strip-blank">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>

        <aside class="profile-stack" aria-hidden="true">
          <div class="profile-visual">
            <span class="profile-core"></span>
            <span class="profile-ring profile-ring-a"></span>
            <span class="profile-ring profile-ring-b"></span>
          </div>

          <div class="signal-panel signal-panel-blank">
            {Array.from({ length: 4 }).map(() => (
              <div class="signal-row">
                <span></span>
                <strong></strong>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section id="works" class="content-section works-section image-section" aria-label="第三部分图片">
      <div class="section-shell">
        <div class="image-stage-grid" aria-hidden="true">
          {workImages.map((image, index) => (
            <figure class={`work-image-card work-image-card-${index + 1}`}>
              <img src={image} alt="" loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="blog" class="content-section archive-section visual-section" aria-label="第四部分">
      <div class="section-shell archive-grid" aria-hidden="true">
        <div class="archive-panel archive-panel-large">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="archive-stack">
          {Array.from({ length: 3 }).map(() => (
            <div class="archive-row">
              <i></i>
              <b></b>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="content-section contact-section visual-section" aria-label="第五部分">
      <div class="section-shell contact-grid contact-grid-visual" aria-hidden="true">
        <div class="visual-copy">
          <span class="visual-kicker"></span>
          <span class="visual-title"></span>
          <span class="visual-title visual-title-short"></span>
          <div class="visual-paragraph">
            <span></span>
            <span></span>
          </div>
        </div>

        <div class="contact-panel contact-panel-blank">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </section>

    <footer class="site-footer visual-footer" aria-hidden="true">
      <div class="footer-inner">
        <span></span>
        <span></span>
      </div>
    </footer>
  </main>
</BaseLayout>

    image: "",
    position: "center",
    map: { x: 23, y: 76, layer: "非线性系统" },
    zone: "chaos",
    discovery: "混沌不是随机；它只是对最初那一点差异异常诚实。"
  },
  {
    id: "lightwell",
    label: "光谱井",

  },
  {
    ...nodeDefaults,
    id: "atrium-to-lightwell",
    scene: "atrium",
    mode: "trace",
    label: "光谱井",
    code: "01—05",
    x: 72,
    y: 38,
    labelX: 0,
    labelY: 0,
    labelAlign: "center",
    targetScene: "lightwell",
    routeLabel: "进入视听生成预留区",
    sentence: "声音、颜色和数据会在这里被转换成实时图形。",
    signal: "SIGNAL / OPEN"
  },
  {
    ...nodeDefaults,
    id: "highland-to-atrium",
    scene: "highland",
    mode: "drift",
    label: "入口庭",
    code: "02—01",
    x: 22,
    y: 70,
    labelX: 0,
    labelY: 0,
    labelAlign: "center",
    targetScene: "atrium",
    routeLabel: "返回网站索引",
    sentence: "回到所有路径的共同入口。",

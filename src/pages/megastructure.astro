---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (path: string) => `${basePath}${path}`;
const supabaseConfig = {
  url:
    import.meta.env.PUBLIC_SUPABASE_URL ||
    import.meta.env.NEXT_PUBLIC_SUPABASE_URL ||
    "https://eaoxzkdowmaibjnphnmu.supabase.co",
  key:
    import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
    import.meta.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
    "sb_publishable_3XfkcJuOqqFKjLcWIyaB_g_5B5mmZGR"
};

const sceneImagePaths = {
  atrium: "assets/megastructure/atrium-cold-concrete.webp",
  highland: "assets/megastructure/scene-highland-city-v1.webp",
  lightwell: "assets/megastructure/scene-lightwell-service-v1.webp"
} as const;
const sceneImagePathFor = (sceneId: keyof typeof sceneImagePaths) =>
  sceneImagePaths[sceneId] ?? sceneImagePaths.atrium;
const sceneImageFor = (sceneId: keyof typeof sceneImagePaths) => assetPath(sceneImagePathFor(sceneId));
const nodeImagePaths = {
  "fog-gallery": "assets/megastructure/node-fog-gallery-v2.webp",
  "highland-city": "assets/megastructure/scene-highland-city-v1.webp",
  "lightwell-service": "assets/megastructure/scene-lightwell-service-v1.webp"
} as const;
const nodeImagePathFor = (nodeId: keyof typeof nodeImagePaths) =>
  nodeImagePaths[nodeId] ?? nodeImagePaths["fog-gallery"];
const nodeImageFor = (nodeId: keyof typeof nodeImagePaths) => assetPath(nodeImagePathFor(nodeId));

const scenes = [
  {
    id: "atrium",
    label: "中庭",
    code: "SCENE 01",
    primaryNode: "fog-gallery",
    kicker: "冷灰混凝土 / 阈限漂移 / 粗野主义结构",
    status: "ATRIUM / INTERNAL VOID",
    description: "冷灰混凝土中庭重新吞回路径，雾廊和柱脚把出口折回原点。",
    imagePath: sceneImagePathFor("atrium"),
    image: sceneImageFor("atrium"),
    position: "center"
  },
  {
    id: "highland",
    label: "高原",
    code: "SCENE 02",
    primaryNode: "highland-city",
    kicker: "高原盆地 / 远距塔群 / 无人环线",
    status: "HIGHLAND / OUTER CITY",
    description: "高原盆地把视野拉远，巨构塔群从湿冷地表垂直升起。",
    imagePath: sceneImagePathFor("highland"),
    image: sceneImageFor("highland"),
    position: "center"
  },
  {
    id: "lightwell",
    label: "光井",
    code: "SCENE 03",
    primaryNode: "lightwell-service",
    kicker: "服务中庭 / 垂直光井 / 湿地反射",
    status: "LIGHTWELL / SERVICE CORE",
    description: "光井层转入室内核心，垂直光带切开服务结构和潮湿地面。",
    imagePath: sceneImagePathFor("lightwell"),
    image: sceneImageFor("lightwell"),
    position: "center"
  }
];

const modes = [
  {
    id: "structure",
    label: "结构",
    code: "FRAME",
    phrase: "城市被压成一套可插拔骨架。",
    status: "MASS 92 / GRID 44",
    accent: "rgba(226, 232, 229, 0.92)",
    haze: "rgba(154, 170, 170, 0.18)"
  },
  {
    id: "liminal",
    label: "阈限",
    code: "DRIFT",
    phrase: "空间没有路线，只保留进入之后的迟疑。",
    status: "EXIT 01 / TRUST 03",
    accent: "rgba(190, 213, 214, 0.9)",
    haze: "rgba(154, 178, 184, 0.22)"
  },
  {
    id: "signal",
    label: "信号",
    code: "TRACE",
    phrase: "每个节点只回传一张小图和一句残留文本。",
    status: "NOISE 07 / ECHO 19",
    accent: "rgba(218, 226, 220, 0.88)",
    haze: "rgba(184, 190, 178, 0.16)"
  }
];

const nodes = [
  {
    id: "fog-gallery",
    scene: "atrium",
    mode: "liminal",
    label: "雾廊",
    code: "A-01",
    x: 34,
    y: 58,
    labelX: -0.3,
    labelY: 2.5,
    labelAlign: "center",
    targetScene: "highland",
    routeLabel: "进入高原盆地",
    sentence: "高原盆地把视野拉远，巨构塔群从湿冷地表垂直升起。",
    signal: "LIGHT 12 / ECHO 04"
  },
  {
    id: "highland-city",
    scene: "highland",
    mode: "structure",
    label: "高原城",
    code: "G-22",
    x: 50,
    y: 47,
    labelX: 0,
    labelY: 2.75,
    labelAlign: "center",
    targetScene: "lightwell",
    routeLabel: "进入垂直光井",
    sentence: "光井层转入室内核心，垂直光带切开服务结构和潮湿地面。",
    signal: "RING 31 / CLOUD 08"
  },
  {
    id: "lightwell-service",
    scene: "lightwell",
    mode: "signal",
    label: "光井层",
    code: "H-31",
    x: 52,
    y: 38,
    labelX: 3.25,
    labelY: 0.2,
    labelAlign: "left",
    targetScene: "atrium",
    routeLabel: "回到冷灰中庭",
    sentence: "冷灰混凝土中庭重新吞回路径，雾廊和柱脚把出口折回原点。",
    signal: "LUX 44 / HUM 16"
  }
];

const nodeQuality = {
  "fog-gallery": { integrity: 61, noise: 28, drift: "SLOW" },
  "highland-city": { integrity: 81, noise: 18, drift: "FAR" },
  "lightwell-service": { integrity: 63, noise: 24, drift: "CORE" }
};

const nodeViewport = {
  "fog-gallery": { frame: "OBS A-01 / FOG", x: 31, y: 44, slit: 30 },
  "highland-city": { frame: "OBS G-22 / BASIN", x: 50, y: 46, slit: 34 },
  "lightwell-service": { frame: "OBS H-31 / CORE", x: 53, y: 39, slit: 22 }
};

const qualityFor = (nodeId: keyof typeof nodeQuality) => nodeQuality[nodeId] ?? nodeQuality["fog-gallery"];
const viewportFor = (nodeId: keyof typeof nodeViewport) => nodeViewport[nodeId] ?? nodeViewport["fog-gallery"];
const panelSignalFor = (quality: { integrity: number; noise: number }) => {
  const wear = Math.min(0.58, Math.max(0.2, quality.noise * 0.006 + (100 - quality.integrity) * 0.003));
  const signalBreak = Math.min(82, Math.max(22, Math.round(quality.noise * 1.42 + 10)));
  const scratch = Math.min(78, Math.max(22, Math.round(((quality.integrity + quality.noise) % 54) + 22)));

  return {
    wear: wear.toFixed(2),
    signalBreak: `${signalBreak}%`,
    scratch: `${scratch}%`
  };
};
const nodesWithQuality = nodes.map((node) => ({
  ...node,
  quality: qualityFor(node.id as keyof typeof nodeQuality),
  viewport: viewportFor(node.id as keyof typeof nodeViewport),
  imagePath: nodeImagePathFor(node.id as keyof typeof nodeImagePaths),
  image: nodeImageFor(node.id as keyof typeof nodeImagePaths)
}));
const firstMode = modes[0];
const firstNode = nodesWithQuality[0];
const firstScene = scenes[0];
const firstNodeDescription = firstScene.description;
const firstPanelSignal = panelSignalFor(firstNode.quality);
---

<BaseLayout
  title="巨构主义"
  description="巨构主义、阈限空间与粗野主义混凝土空间的交互观察器。"
  image="assets/megastructure/atrium-cold-concrete.webp"
  imageAlt="冷灰混凝土巨构空间中庭"
  imageWidth={1536}
  imageHeight={1024}
  skipTarget="#megastructure-main"
  preloadImages={[
    ...scenes.map((scene, index) => ({
      href: scene.imagePath,
      type: "image/webp",
      fetchPriority: index === 0 ? "high" : "auto"
    })),
    ...nodesWithQuality.map((node, index) => ({
      href: node.imagePath,
      type: "image/webp",
      fetchPriority: index === 0 ? "high" : "auto"
    }))
  ]}
>
  <main
    id="megastructure-main"
    class="mega-lab"
    data-mega-lab
    data-active-scene={firstScene.id}
    style={`--node-image: url("${firstNode.image}"); --focus-x: ${firstNode.x}%; --focus-y: ${firstNode.y}%; --map-x: ${firstNode.x}%; --map-y: ${firstNode.y}%; --scene-position: ${firstScene.position}; --mode-accent: ${firstMode.accent}; --mode-haze: ${firstMode.haze}; --stage-scale: 1.05; --node-integrity: ${firstNode.quality.integrity}; --node-noise: ${firstNode.quality.noise}; --panel-wear: ${firstPanelSignal.wear}; --panel-break: ${firstPanelSignal.signalBreak}; --panel-scratch: ${firstPanelSignal.scratch};`}
  >
    <section class="mega-lab-stage" aria-label="巨构主义空间观察器">
      <img
        class="mega-lab-backdrop"
        data-scene-backdrop
        src={firstScene.image}
        alt=""
        width="1536"
        height="864"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        draggable="false"
      />
      <div class="mega-lab-grid" aria-hidden="true"></div>
      <div class="mega-lab-haze" aria-hidden="true"></div>
      <div class="mega-depth-field" aria-hidden="true">
        <span class="mega-depth-slab mega-depth-slab-1"></span>
        <span class="mega-depth-slab mega-depth-slab-2"></span>
        <span class="mega-depth-slab mega-depth-slab-3"></span>
      </div>
      <div class="mega-ground-sheen" aria-hidden="true"></div>

      <header class="mega-lab-topbar" aria-label="巨构主义页面导航">
        <a href={basePath}>灰雨电台</a>
        <span>MEGASTRUCTURE OBSERVER</span>
        <div class="mega-topbar-actions">
          <button class="mega-admin-comment-button" type="button" data-comment-admin-open hidden>
            评论
            <b data-comment-pending-count>0</b>
          </button>
        </div>
      </header>

      <section class="mega-lab-title" aria-label="页面标题">
        <p data-scene-kicker>{firstScene.kicker}</p>
        <small data-mode-phrase>{firstNodeDescription}</small>
      </section>

      <div class="mega-node-plane" aria-label="空间节点">
        {
          nodesWithQuality.map((node, index) => (
            <button
              type="button"
              class={`mega-lab-node${index === 0 ? " is-active" : ""}${node.scene !== firstScene.id ? " is-scene-hidden" : ""}`}
              data-node-button={node.id}
              data-node-mode={node.mode}
              data-node-scene={node.scene}
              style={`--x: ${node.x}%; --y: ${node.y}%; --label-x: ${node.labelX}rem; --label-y: ${node.labelY}rem; --label-align: ${node.labelAlign};`}
              aria-label={`路径节点 ${node.code} ${node.label}，${node.routeLabel}`}
              aria-pressed={index === 0 ? "true" : "false"}
              aria-hidden={node.scene !== firstScene.id ? "true" : "false"}
              tabindex={node.scene !== firstScene.id ? "-1" : "0"}
            >
              <span class="mega-node-cross" aria-hidden="true"></span>
              <span class="mega-node-text">{node.label}</span>
            </button>
          ))
        }
      </div>
      <div class="mega-route-console" aria-label="场景路径关系">
        <div class="mega-route-status">
          <span data-route-current>{firstScene.label}</span>
          <b data-route-link>{firstScene.status}</b>
        </div>
        <button class="mega-route-back" type="button" data-route-back disabled>
          <small data-route-back-context>RETURN</small>
          <strong data-route-back-label>无返回</strong>
          <span data-route-back-description>无上一个背景</span>
        </button>
      </div>

      <div class="mega-comment-layer" data-comment-layer aria-label="Position comments"></div>
      <button class="mega-comment-toggle" type="button" data-comment-toggle aria-pressed="true">隐藏标记</button>
      <aside class="mega-comment-popover" data-comment-popover hidden aria-live="polite">
        <div class="mega-comment-head">
          <span data-comment-title>评论</span>
          <button type="button" data-comment-close aria-label="Close comment panel">x</button>
        </div>
        <p class="mega-comment-position" data-comment-position>X 00.0 / Y 00.0</p>
        <div class="mega-comment-auth" data-comment-auth>
          <input type="text" data-comment-name autocomplete="username" maxlength="24" placeholder="名称（注册用）" />
          <input type="email" data-comment-email autocomplete="email" maxlength="80" placeholder="账号邮箱" />
          <input
            type="password"
            data-comment-password
            autocomplete="current-password"
            maxlength="32"
            placeholder="密码（至少 6 位）"
          />
          <div>
            <button type="button" data-comment-login>登录</button>
            <button type="button" data-comment-register>注册</button>
          </div>
        </div>
        <div class="mega-comment-session" data-comment-session hidden>
          <span data-comment-user>用户 / -</span>
          <button type="button" data-comment-logout>退出</button>
        </div>
        <form class="mega-comment-form" data-comment-form hidden>
          <textarea data-comment-text maxlength="180" rows="4" placeholder="写下评论"></textarea>
          <button type="submit">提交审核</button>
        </form>
        <div class="mega-comment-detail" data-comment-detail hidden></div>
        <div class="mega-comment-list" data-comment-list></div>
        <div class="mega-comment-review" data-comment-review hidden>
          <span>待审核</span>
          <div data-comment-review-list></div>
        </div>
      </aside>
      <aside class="mega-comment-admin-dialog" data-comment-admin-dialog hidden aria-live="polite" aria-label="评论审核面板">
        <div class="mega-comment-head">
          <span>评论审核</span>
          <button type="button" data-comment-admin-close aria-label="Close comment review panel">x</button>
        </div>
        <p class="mega-comment-admin-summary" data-comment-admin-summary>全部评论 / 0</p>
        <div class="mega-comment-admin-filters" aria-label="评论状态筛选">
          <button type="button" class="is-active" data-comment-admin-filter="pending" aria-pressed="true">
            <span>待审核</span>
            <b>0</b>
          </button>
          <button type="button" data-comment-admin-filter="approved" aria-pressed="false">
            <span>已通过</span>
            <b>0</b>
          </button>
          <button type="button" data-comment-admin-filter="rejected" aria-pressed="false">
            <span>已拒绝</span>
            <b>0</b>
          </button>
        </div>
        <div class="mega-comment-admin-list" data-comment-admin-list></div>
      </aside>

    </section>

    <section class="mega-design-strip" aria-label="功能设计摘要">
      <article>
        <span>01 / ATRIUM</span>
        <p>中庭只保留雾廊入口，点击后进入外部高原。</p>
      </article>
      <article>
        <span>02 / HIGHLAND</span>
        <p>高原场景把观察距离拉远，巨构从盆地里升起。</p>
      </article>
      <article>
        <span>03 / LIGHTWELL</span>
        <p>光井场景只保留核心返回节点，压迫感来自垂直结构。</p>
      </article>
      <article>
        <span>04 / RETURN</span>
        <p>底部返回节点记录上一个场景，形成可回退的路径。</p>
      </article>
    </section>
  </main>

  <script define:vars={{ modes, scenes, nodes: nodesWithQuality, supabaseConfig }}>
      const lab = document.querySelector("[data-mega-lab]");

      if (lab) {
        const modeButtons = Array.from(lab.querySelectorAll("[data-mode-button]"));
        const nodeButtons = Array.from(lab.querySelectorAll("[data-node-button]"));
      const audioButton = lab.querySelector("[data-audio-toggle]");
      const panelCollapseButton = lab.querySelector("[data-panel-collapse]");
      const panelReopenButton = lab.querySelector("[data-panel-reopen]");
      const panelDragHandle = lab.querySelector("[data-panel-drag]");
      const panelResizeHandle = lab.querySelector("[data-panel-resize]");
      const scaleRange = lab.querySelector("[data-scale-range]");
      const scaleValue = lab.querySelector("[data-scale-value]");
      const sceneBackdrop = lab.querySelector("[data-scene-backdrop]");
      const sceneKicker = lab.querySelector("[data-scene-kicker]");
      const routeBackButton = lab.querySelector("[data-route-back]");
      const routeBackContext = lab.querySelector("[data-route-back-context]");
      const routeBackLabel = lab.querySelector("[data-route-back-label]");
      const routeBackDescription = lab.querySelector("[data-route-back-description]");
      const routeCurrent = lab.querySelector("[data-route-current]");
      const routeLink = lab.querySelector("[data-route-link]");
      const modePhrase = lab.querySelector("[data-mode-phrase]");
      const modeCode = lab.querySelector("[data-mode-code]");
      const nodeCode = lab.querySelector("[data-node-code]");
      const nodeTitle = lab.querySelector("[data-node-title]");
      const nodeSentence = lab.querySelector("[data-node-sentence]");
      const nodeSignal = lab.querySelector("[data-node-signal]");
      const reopenCode = lab.querySelector("[data-reopen-code]");
      const panelScreen = lab.querySelector("[data-panel-screen]");
      const panelFrameCode = lab.querySelector("[data-panel-frame-code]");
      const locatorCode = lab.querySelector("[data-locator-code]");
      const qualityIntegrity = lab.querySelector("[data-quality-integrity]");
      const qualityNoise = lab.querySelector("[data-quality-noise]");
      const qualityDrift = lab.querySelector("[data-quality-drift]");
      const qualityMeterIntegrity = lab.querySelector("[data-quality-meter-integrity]");
      const qualityMeterNoise = lab.querySelector("[data-quality-meter-noise]");
      const observerPanel = lab.querySelector(".mega-observer-panel");
      const labStage = lab.querySelector(".mega-lab-stage");
      const commentLayer = lab.querySelector("[data-comment-layer]");
      const commentToggleButton = lab.querySelector("[data-comment-toggle]");
      const commentAdminOpenButton = lab.querySelector("[data-comment-admin-open]");
      const commentPendingCount = lab.querySelector("[data-comment-pending-count]");
      const commentAdminDialog = lab.querySelector("[data-comment-admin-dialog]");
      const commentAdminCloseButton = lab.querySelector("[data-comment-admin-close]");
      const commentAdminSummary = lab.querySelector("[data-comment-admin-summary]");
      const commentAdminFilterButtons = Array.from(lab.querySelectorAll("[data-comment-admin-filter]"));
      const commentAdminList = lab.querySelector("[data-comment-admin-list]");
      const commentPopover = lab.querySelector("[data-comment-popover]");
      const commentTitle = lab.querySelector("[data-comment-title]");
      const commentPosition = lab.querySelector("[data-comment-position]");
      const commentCloseButton = lab.querySelector("[data-comment-close]");
      const commentAuth = lab.querySelector("[data-comment-auth]");
      const commentName = lab.querySelector("[data-comment-name]");
      const commentEmail = lab.querySelector("[data-comment-email]");
      const commentPassword = lab.querySelector("[data-comment-password]");
      const commentLoginButton = lab.querySelector("[data-comment-login]");
      const commentRegisterButton = lab.querySelector("[data-comment-register]");
      const commentSessionPanel = lab.querySelector("[data-comment-session]");
      const commentUser = lab.querySelector("[data-comment-user]");
      const commentLogoutButton = lab.querySelector("[data-comment-logout]");
      const commentForm = lab.querySelector("[data-comment-form]");
      const commentText = lab.querySelector("[data-comment-text]");
      const commentDetail = lab.querySelector("[data-comment-detail]");
      const commentList = lab.querySelector("[data-comment-list]");
      const commentReview = lab.querySelector("[data-comment-review]");
      const commentReviewList = lab.querySelector("[data-comment-review-list]");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      let activeSceneId = scenes[0].id;
      let activeModeId = modes[0].id;
      let activeNodeId = nodes[0].id;
      let lastNodeId = activeNodeId;
      let sceneHistory = [];
      let isPanelCollapsed = false;
      let pointerFrame = 0;
      let audioContext = null;
      let lowOscillator = null;
      let overtoneOscillator = null;
      let lowGain = null;
      let presenceGain = null;
      let gain = null;
      let panelGesture = null;
      let panelFrame = 0;
      let pendingPanelBox = null;
      let pendingPanelMode = "floating";
      let comments = [];
      let activeCommentAdminFilter = "pending";
      let currentCommentUser = "";
      let currentCommentUserId = "";
      let currentCommentRole = "user";
      let currentCommentLocked = false;
      let commentSession = null;
      let commentDraftPoint = null;
      let commentPressTimer = 0;
      let commentPressStart = null;
      let commentOpenedAt = 0;
      let commentReleaseClickPoint = null;
      let commentLoadId = 0;
      const commentCache = new Map();
      let selectedCommentId = "";
      let areCommentsVisible = true;
      const commentKeys = {
        remoteSession: "mega-comment-supabase-session-v1",
        visibility: "mega-comment-visibility-v1",
        visitSession: "mega-visit-session-v1"
      };
      const commentHoldMs = 620;
      const commentSupabaseUrl = String(supabaseConfig?.url || "").replace(/\/$/, "");
      const commentSupabaseKey = String(supabaseConfig?.key || "");
      const hasRemoteComments = Boolean(commentSupabaseUrl && commentSupabaseKey);

      const findMode = (modeId) => modes.find((mode) => mode.id === modeId) || modes[0];
      const findScene = (sceneId) => scenes.find((scene) => scene.id === sceneId) || scenes[0];
      const findNode = (nodeId) => nodes.find((node) => node.id === nodeId) || nodes[0];
      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

      const nodeForScene = (sceneId) => {
        const scene = findScene(sceneId);
        return findNode(scene.primaryNode) || nodes.find((node) => node.scene === scene.id) || nodes[0];
      };

      const nodeTargetDescription = (node) => {
        const targetScene = findScene(node?.targetScene || node?.scene);
        return targetScene.description || node?.sentence || targetScene.status;
      };

      const commentPageForScene = (sceneId = activeSceneId) => `megastructure:${findScene(sceneId).id}`;
      const commentPageFilterForScene = (sceneId = activeSceneId) => {
        const scene = findScene(sceneId);
        const page = encodeURIComponent(commentPageForScene(scene.id));
        return scene.id === "atrium" ? `page=in.(${page},megastructure)` : `page=eq.${page}`;
      };

      const updateRouteUi = (routeNode = null) => {
        const scene = findScene(activeSceneId);
        const previousScene = sceneHistory.length ? findScene(sceneHistory[sceneHistory.length - 1]) : null;

        if (routeCurrent) routeCurrent.textContent = scene.label;

        if (routeLink) {
          routeLink.textContent = routeNode
            ? `${routeNode.routeLabel} / ${findScene(routeNode.scene).label} -> ${scene.label}`
            : scene.status;
        }

        if (routeBackButton) {
          routeBackButton.disabled = !previousScene;
          routeBackButton.setAttribute("aria-disabled", String(!previousScene));
        }

        if (routeBackLabel) {
          routeBackLabel.textContent = previousScene ? previousScene.label : "无返回";
        }

        if (routeBackContext) {
          routeBackContext.textContent = previousScene ? `RETURN / ${previousScene.label}` : "RETURN";
        }

        if (routeBackDescription) {
          routeBackDescription.textContent = previousScene ? previousScene.description : "无上一个背景";
        }

      };

      const applyScene = (sceneId) => {
        const scene = findScene(sceneId);
        activeSceneId = scene.id;
        lab.dataset.activeScene = scene.id;
        lab.style.setProperty("--scene-position", scene.position || "center");

        if (sceneBackdrop && scene.image && sceneBackdrop.getAttribute("src") !== scene.image) {
          sceneBackdrop.setAttribute("src", scene.image);
        }

        if (sceneKicker) sceneKicker.textContent = scene.kicker;
        if (modePhrase) modePhrase.textContent = scene.description || scene.status;
        nodeButtons.forEach((button) => {
          const isCurrentSceneNode = button.dataset.nodeScene === scene.id;
          button.classList.toggle("is-scene-hidden", !isCurrentSceneNode);
          button.setAttribute("aria-hidden", String(!isCurrentSceneNode));
          button.setAttribute("tabindex", isCurrentSceneNode ? "0" : "-1");
        });
      };

      const setMeter = (meter, value) => {
        if (!meter) {
          return;
        }

        meter.style.setProperty("--meter", String(value) + "%");
        meter.setAttribute("aria-valuenow", String(value));
      };

      const setSignalQuality = (node) => {
        const quality = node.quality || { integrity: 0, noise: 0, drift: "NONE" };
        const panelWear = Math.min(0.58, Math.max(0.2, quality.noise * 0.006 + (100 - quality.integrity) * 0.003));
        const panelBreak = Math.min(82, Math.max(22, Math.round(quality.noise * 1.42 + 10)));
        const panelScratch = Math.min(78, Math.max(22, Math.round(((quality.integrity + quality.noise) % 54) + 22)));
        lab.style.setProperty("--node-integrity", String(quality.integrity));
        lab.style.setProperty("--node-noise", String(quality.noise));
        lab.style.setProperty("--panel-wear", panelWear.toFixed(2));
        lab.style.setProperty("--panel-break", String(panelBreak) + "%");
        lab.style.setProperty("--panel-scratch", String(panelScratch) + "%");

        if (qualityIntegrity) qualityIntegrity.textContent = String(quality.integrity);
        if (qualityNoise) qualityNoise.textContent = String(quality.noise);
        if (qualityDrift) qualityDrift.textContent = quality.drift;
        setMeter(qualityMeterIntegrity, quality.integrity);
        setMeter(qualityMeterNoise, quality.noise);
      };

      const setPanelViewport = (node) => {
        const viewport = node.viewport || { frame: node.code, x: 50, y: 50, slit: 28 };
        const nodeImage = node.image || nodes[0].image;

        if (panelFrameCode) panelFrameCode.textContent = viewport.frame;
        if (nodeImage) lab.style.setProperty("--node-image", `url("${nodeImage}")`);

        if (panelScreen) {
          if (nodeImage) panelScreen.style.setProperty("--node-image", `url("${nodeImage}")`);
          panelScreen.style.setProperty("--viewport-x", String(viewport.x) + "%");
          panelScreen.style.setProperty("--viewport-y", String(viewport.y) + "%");
          panelScreen.style.setProperty("--viewport-slit", String(viewport.slit) + "%");
        }
      };

      const normalizeCommentName = (value) => String(value || "").trim().replace(/\s+/g, " ").slice(0, 24);

      const normalizeCommentEmail = (value) => String(value || "").trim().toLowerCase().slice(0, 80);

      const commentErrorText = (error, fallback = "操作失败") => {
        const message = String(error?.message || error || "");

        if (/email not confirmed/i.test(message)) {
          return "邮箱未确认，请检查注册邮箱的确认邮件";
        }
        if (/invalid login credentials/i.test(message)) {
          return "账号邮箱或密码错误";
        }
        if (/user already registered|already registered|already exists|duplicate key/i.test(message)) {
          return "邮箱已经注册";
        }
        if (/rate limit|too many|email rate/i.test(message)) {
          return "请求过于频繁，请稍后再试";
        }
        if (/permission denied/i.test(message)) {
          return "数据库权限不足，请先执行 Supabase SQL 脚本";
        }
        if (/could not find|schema cache|relation .* does not exist|function .* does not exist/i.test(message)) {
          return "数据库脚本未更新，请先执行 Supabase SQL 脚本";
        }
        if (/database error/i.test(message)) {
          return "数据库写入失败，请检查 Supabase SQL 脚本";
        }
        if (/supabase config missing/i.test(message)) {
          return "评论服务未配置";
        }

        return fallback;
      };

      const commentAuthHeaders = (useSession = true) => {
        const token = useSession && commentSession?.access_token ? commentSession.access_token : commentSupabaseKey;
        return {
          apikey: commentSupabaseKey,
          Authorization: `Bearer ${token}`,
          "Content-Type": "application/json"
        };
      };

      const requestCommentApi = async (path, options = {}, useSession = true) => {
        if (!hasRemoteComments) {
          throw new Error("Supabase config missing");
        }

        const response = await fetch(`${commentSupabaseUrl}${path}`, {
          ...options,
          headers: {
            ...commentAuthHeaders(useSession),
            ...(options.headers || {})
          }
        });
        const text = await response.text();
        const data = text ? JSON.parse(text) : null;

        if (!response.ok) {
          throw new Error(data?.msg || data?.message || `Supabase request failed: ${response.status}`);
        }

        return data;
      };

      const requestCommentRpc = (name, payload = {}, useSession = true) =>
        requestCommentApi(
          `/rest/v1/rpc/${encodeURIComponent(name)}`,
          {
            method: "POST",
            body: JSON.stringify(payload)
          },
          useSession
        );

      const firstCommentRpcRow = (data) => (Array.isArray(data) ? data[0] || null : data);

      const booleanCommentRpcValue = (data) => {
        const value = firstCommentRpcRow(data);

        if (typeof value === "boolean") {
          return value;
        }
        if (value && typeof value === "object") {
          return Boolean(Object.values(value)[0]);
        }

        return Boolean(value);
      };

      const normalizeCommentLockStatus = (data) => {
        const row = firstCommentRpcRow(data) || {};

        return {
          emailRegistered: Boolean(row.email_registered),
          isLocked: Boolean(row.is_locked),
          failedCount: Number(row.failed_count || 0)
        };
      };

      const getCommentEmailRegistered = async (email) =>
        booleanCommentRpcValue(await requestCommentRpc("comment_email_registered", { p_email: email }, false));

      const getCommentLockStatus = async (email) =>
        normalizeCommentLockStatus(await requestCommentRpc("comment_login_lock_status", { p_email: email }, false));

      const registerCommentLoginFailure = async (email) =>
        normalizeCommentLockStatus(await requestCommentRpc("register_comment_login_failure", { p_email: email }, false));

      const clearCommentLoginFailures = () => requestCommentRpc("clear_comment_login_failures", {}, true);

      const saveCommentSession = () => {
        try {
          if (commentSession) {
            window.localStorage.setItem(commentKeys.remoteSession, JSON.stringify(commentSession));
          } else {
            window.localStorage.removeItem(commentKeys.remoteSession);
          }
        } catch {}
      };

      const loadCommentVisibilityPreference = () => {
        try {
          areCommentsVisible = window.localStorage.getItem(commentKeys.visibility) !== "hidden";
        } catch {
          areCommentsVisible = true;
        }
      };

      const saveCommentVisibilityPreference = () => {
        try {
          window.localStorage.setItem(commentKeys.visibility, areCommentsVisible ? "visible" : "hidden");
        } catch {}
      };

      const updateCommentVisibilityControl = () => {
        lab.classList.toggle("is-comments-hidden", !areCommentsVisible);

        if (!commentToggleButton) {
          return;
        }

        commentToggleButton.textContent = areCommentsVisible ? "隐藏标记" : "显示标记";
        commentToggleButton.setAttribute("aria-pressed", String(areCommentsVisible));
        commentToggleButton.setAttribute(
          "aria-label",
          areCommentsVisible ? "隐藏所有评论标记，长按仍可写评论" : "显示评论标记"
        );
      };

      const setCommentsVisible = (visible) => {
        areCommentsVisible = Boolean(visible);
        saveCommentVisibilityPreference();

        if (!areCommentsVisible) {
          closeCommentPanel();
        }

        renderCommentUi();
      };

      const profileNameFromSession = () =>
        normalizeCommentName(
          commentSession?.user?.user_metadata?.display_name ||
            commentSession?.user?.email?.split("@")[0] ||
            "用户"
        );

      const loadCurrentCommentProfile = async () => {
        currentCommentUserId = commentSession?.user?.id || "";
        currentCommentRole = "user";
        currentCommentLocked = false;
        currentCommentUser = currentCommentUserId ? profileNameFromSession() : "";

        if (!currentCommentUserId) {
          return;
        }

        const rows = await requestCommentApi(
          `/rest/v1/comment_profiles?id=eq.${encodeURIComponent(currentCommentUserId)}&select=display_name,role,is_locked,failed_login_count&limit=1`
        );
        const profile = Array.isArray(rows) ? rows[0] : null;

        if (profile?.display_name) {
          currentCommentUser = normalizeCommentName(profile.display_name);
        }
        if (profile?.role) {
          currentCommentRole = profile.role;
        }
        currentCommentLocked = Boolean(profile?.is_locked);
      };

      const applyCommentSession = async (session) => {
        commentSession = session || null;
        await loadCurrentCommentProfile();
        saveCommentSession();
      };

      const refreshCommentSession = async () => {
        if (!commentSession?.refresh_token) {
          return false;
        }

        const refreshed = await requestCommentApi(
          "/auth/v1/token?grant_type=refresh_token",
          {
            method: "POST",
            body: JSON.stringify({ refresh_token: commentSession.refresh_token })
          },
          false
        );
        await applyCommentSession(refreshed);
        return true;
      };

      const restoreCommentSession = async () => {
        try {
          const stored = window.localStorage.getItem(commentKeys.remoteSession);
          commentSession = stored ? JSON.parse(stored) : null;
        } catch {
          commentSession = null;
        }

        if (!commentSession?.access_token) {
          currentCommentUser = "";
          currentCommentUserId = "";
          currentCommentRole = "user";
          currentCommentLocked = false;
          return;
        }

        try {
          await loadCurrentCommentProfile();
          if (currentCommentLocked) {
            commentSession = null;
            currentCommentUser = "";
            currentCommentUserId = "";
            currentCommentRole = "user";
            currentCommentLocked = false;
            saveCommentSession();
          }
        } catch (error) {
          try {
            await refreshCommentSession();
          } catch {
            commentSession = null;
            currentCommentUser = "";
            currentCommentUserId = "";
            currentCommentRole = "user";
            currentCommentLocked = false;
            saveCommentSession();
            console.warn("Comment session restore failed", error);
          }
        }
      };

      const mapRemoteComment = (row) => {
        const profile = Array.isArray(row.comment_profiles) ? row.comment_profiles[0] : row.comment_profiles;
        return {
          id: row.id,
          author: normalizeCommentName(profile?.display_name || "用户"),
          authorEmail: normalizeCommentEmail(profile?.email || ""),
          userId: row.user_id,
          role: profile?.role || "user",
          text: String(row.body || ""),
          x: Number(row.x),
          y: Number(row.y),
          status: row.status || "pending",
          createdAt: row.created_at,
          reviewedAt: row.reviewed_at || "",
          reviewReason: String(row.review_reason || ""),
          reviewScore: Number(row.review_score || 0),
          reviewLabels: Array.isArray(row.review_labels) ? row.review_labels : [],
          reviewedBy: String(row.reviewed_by || "")
        };
      };

      const loadRemoteComments = async (sceneId = activeSceneId) => {
        const page = commentPageForScene(sceneId);
        const pageFilter = commentPageFilterForScene(sceneId);
        const requestId = ++commentLoadId;
        const profileSelect = isCommentAdmin() ? "display_name,email,role" : "display_name,role";
        const rows = await requestCommentApi(
          `/rest/v1/megastructure_comments?select=id,body,x,y,status,created_at,reviewed_at,review_reason,review_score,review_labels,reviewed_by,user_id,comment_profiles(${profileSelect})&${pageFilter}&order=created_at.desc`
        );

        if (requestId !== commentLoadId || sceneId !== activeSceneId) {
          return;
        }

        const nextComments = Array.isArray(rows) ? rows.map(mapRemoteComment) : [];
        commentCache.set(page, nextComments);
        comments = nextComments;
      };

      const saveCommentState = () => {
        saveCommentSession();
      };

      const getVisitSessionId = () => {
        try {
          const stored = window.localStorage.getItem(commentKeys.visitSession);
          if (stored) {
            return stored;
          }

          const next =
            window.crypto?.randomUUID?.() ||
            `visit-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
          window.localStorage.setItem(commentKeys.visitSession, next);
          return next;
        } catch {
          return `visit-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
        }
      };

      const getConnectionInfo = () => {
        const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        return connection || {};
      };

      const localVisitTimestamp = (date = new Date()) => {
        const pad = (value, length = 2) => String(value).padStart(length, "0");

        return [
          date.getFullYear(),
          pad(date.getMonth() + 1),
          pad(date.getDate())
        ].join("-") + "T" + [
          pad(date.getHours()),
          pad(date.getMinutes()),
          pad(date.getSeconds())
        ].join(":") + "." + pad(date.getMilliseconds(), 3);
      };

      const trackMegastructureVisit = (eventType = "view") => {
        if (!hasRemoteComments) {
          return;
        }

        const connection = getConnectionInfo();
        const payload = {
          event_type: eventType,
          page: "megastructure",
          scene: activeSceneId,
          created_at: localVisitTimestamp(),
          session_id: getVisitSessionId(),
          user_id: currentCommentUserId || null,
          display_name: currentCommentUser || null,
          email: normalizeCommentEmail(commentSession?.user?.email || ""),
          path: window.location.pathname,
          referrer: document.referrer || null,
          user_agent: navigator.userAgent || null,
          language: navigator.language || null,
          timezone: Intl.DateTimeFormat().resolvedOptions().timeZone || null,
          viewport_width: window.innerWidth,
          viewport_height: window.innerHeight,
          screen_width: window.screen?.width || null,
          screen_height: window.screen?.height || null,
          device_pixel_ratio: Number(window.devicePixelRatio || 1),
          hardware_concurrency: navigator.hardwareConcurrency || null,
          device_memory: navigator.deviceMemory || null,
          platform: navigator.platform || null,
          connection_type: connection.type || null,
          effective_type: connection.effectiveType || null,
          downlink: connection.downlink || null,
          reduced_motion: reduceMotion.matches,
          color_scheme: window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light",
          touch_points: navigator.maxTouchPoints || 0
        };

        requestCommentApi(
          "/rest/v1/megastructure_visits",
          {
            method: "POST",
            headers: { Prefer: "return=minimal" },
            body: JSON.stringify(payload)
          },
          Boolean(commentSession?.access_token)
        ).catch((error) => {
          console.warn("Visit tracking failed", error);
        });
      };

      const formatCommentTime = (value) => {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
          return "--:--";
        }

        return date.toLocaleString("zh-CN", {
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit"
        });
      };

      const formatCommentPosition = (point) =>
        `X ${Number(point?.x || 0).toFixed(1)} / Y ${Number(point?.y || 0).toFixed(1)}`;

      const isCommentAdmin = () => currentCommentRole === "admin";

      const commentStatusLabel = (status) => {
        if (status === "approved") {
          return "已通过";
        }
        if (status === "rejected") {
          return "已拒绝";
        }
        return "待审核";
      };

      const commentAdminFilterStatuses = ["pending", "approved", "rejected"];

      const commentAdminEmptyLabel = (status) => {
        if (status === "approved") {
          return "已通过";
        }
        if (status === "rejected") {
          return "已拒绝";
        }
        return "待审核";
      };

      const canManageComment = (comment) =>
        Boolean(comment && currentCommentUserId && (isCommentAdmin() || (!currentCommentLocked && comment.userId === currentCommentUserId)));

      const getCommentPoint = (event) => {
        if (!labStage) {
          return { x: 50, y: 50 };
        }

        const rect = labStage.getBoundingClientRect();
        return {
          x: clamp(((event.clientX - rect.left) / Math.max(rect.width, 1)) * 100, 0, 100),
          y: clamp(((event.clientY - rect.top) / Math.max(rect.height, 1)) * 100, 0, 100)
        };
      };

      const clearCommentPress = () => {
        if (commentPressTimer) {
          window.clearTimeout(commentPressTimer);
          commentPressTimer = 0;
        }
        commentPressStart = null;
      };

      const placeCommentPopover = (point) => {
        if (!commentPopover || !labStage) {
          return;
        }

        const stageRect = labStage.getBoundingClientRect();
        const left = (Number(point.x) / 100) * stageRect.width;
        const top = (Number(point.y) / 100) * stageRect.height;
        commentPopover.hidden = false;

        window.requestAnimationFrame(() => {
          const popRect = commentPopover.getBoundingClientRect();
          const gutter = 16;
          const nextLeft = clamp(left + 16, gutter, Math.max(gutter, stageRect.width - popRect.width - gutter));
          const nextTop = clamp(top + 16, gutter, Math.max(gutter, stageRect.height - popRect.height - gutter));
          commentPopover.style.left = `${nextLeft}px`;
          commentPopover.style.top = `${nextTop}px`;
        });
      };

      const setCommentDetail = (comment) => {
        if (!commentDetail) {
          return;
        }

        commentDetail.textContent = "";
        commentDetail.hidden = !comment;

        if (!comment) {
          return;
        }

        const text = document.createElement("p");
        text.textContent = comment.text;
        const meta = document.createElement("span");
        meta.textContent = `${comment.author} / ${formatCommentTime(comment.createdAt)}`;
        commentDetail.append(text, meta);
      };

      const openCommentPanel = (point, selectedComment = null) => {
        commentDraftPoint = selectedComment ? null : { ...point, sceneId: activeSceneId };
        selectedCommentId = selectedComment?.id || "";
        commentOpenedAt = Date.now();

        if (commentTitle) commentTitle.textContent = selectedComment ? "评论详情" : "评论";
        if (commentPosition) {
          commentPosition.hidden = Boolean(selectedComment);
          commentPosition.textContent = formatCommentPosition(point);
        }
        if (commentText) commentText.value = "";
        setCommentDetail(selectedComment);
        renderCommentUi();
        placeCommentPopover(point);

        window.requestAnimationFrame(() => {
          if (!currentCommentUser) {
            commentName?.focus({ preventScroll: true });
          } else if (!selectedComment) {
            commentText?.focus({ preventScroll: true });
          }
        });
      };

      const closeCommentPanel = () => {
        if (commentPopover) {
          commentPopover.hidden = true;
        }
        commentDraftPoint = null;
        selectedCommentId = "";
        setCommentDetail(null);
      };

      const closeCommentAdminDialog = () => {
        if (commentAdminDialog) {
          commentAdminDialog.hidden = true;
        }
      };

      const createCommentAdminRow = (comment) => {
        const row = document.createElement("article");
        row.className = `mega-comment-admin-row is-${comment.status}`;
        row.dataset.commentId = comment.id;

        const text = document.createElement("p");
        text.textContent = comment.text;

        const meta = document.createElement("dl");
        const metaItems = [
          ["状态", commentStatusLabel(comment.status)],
          ["时间", formatCommentTime(comment.createdAt)],
          ["评论人", comment.author || "-"],
          ["邮箱", comment.authorEmail || "-"],
          ["审核说明", comment.reviewReason || "-"],
          ["风险分", Number.isFinite(comment.reviewScore) ? comment.reviewScore.toFixed(2) : "-"],
          ["审核来源", comment.reviewedBy || "-"]
        ];

        metaItems.forEach(([label, value]) => {
          const term = document.createElement("dt");
          term.textContent = label;
          const detail = document.createElement("dd");
          detail.textContent = value;
          meta.append(term, detail);
        });

        const actions = document.createElement("div");
        actions.className = "mega-comment-review-actions";

        if (comment.status !== "approved") {
          const approve = document.createElement("button");
          approve.type = "button";
          approve.dataset.commentAction = "approve";
          approve.dataset.commentId = comment.id;
          approve.textContent = "通过";
          actions.append(approve);
        }

        if (comment.status !== "rejected") {
          const reject = document.createElement("button");
          reject.type = "button";
          reject.dataset.commentAction = "reject";
          reject.dataset.commentId = comment.id;
          reject.textContent = "拒绝";
          actions.append(reject);
        }

        const remove = document.createElement("button");
        remove.type = "button";
        remove.dataset.commentAction = "delete";
        remove.dataset.commentId = comment.id;
        remove.textContent = "删除";
        actions.append(remove);

        row.append(text, meta, actions);
        return row;
      };

      const renderCommentAdminDialog = () => {
        const adminMode = isCommentAdmin();
        const statusCounts = comments.reduce(
          (counts, comment) => {
            const status = commentAdminFilterStatuses.includes(comment.status) ? comment.status : "pending";
            counts[status] += 1;
            return counts;
          },
          { pending: 0, approved: 0, rejected: 0 }
        );
        const pendingCount = statusCounts.pending;

        if (commentAdminOpenButton) {
          commentAdminOpenButton.hidden = !adminMode;
          commentAdminOpenButton.disabled = !adminMode;
        }
        if (commentPendingCount) {
          commentPendingCount.textContent = String(pendingCount);
          commentPendingCount.setAttribute("aria-label", `${pendingCount} 条待审核评论`);
        }

        if (!adminMode) {
          closeCommentAdminDialog();
          return;
        }

        if (commentAdminSummary) {
          commentAdminSummary.textContent = `全部评论 / ${comments.length}`;
        }

        if (!commentAdminFilterStatuses.includes(activeCommentAdminFilter)) {
          activeCommentAdminFilter = "pending";
        }

        commentAdminFilterButtons.forEach((button) => {
          const status = button.dataset.commentAdminFilter || "pending";
          const isActive = status === activeCommentAdminFilter;
          const count = statusCounts[status] || 0;
          const badge = button.querySelector("b");

          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));

          if (badge) {
            badge.textContent = String(count);
          }
        });

        if (!commentAdminList || commentAdminDialog?.hidden) {
          return;
        }

        commentAdminList.textContent = "";

        const filteredComments = comments.filter((comment) => {
          const status = commentAdminFilterStatuses.includes(comment.status) ? comment.status : "pending";
          return status === activeCommentAdminFilter;
        });

        if (!filteredComments.length) {
          const empty = document.createElement("p");
          empty.className = "mega-comment-admin-empty";
          empty.textContent = `暂无${commentAdminEmptyLabel(activeCommentAdminFilter)}评论`;
          commentAdminList.append(empty);
          return;
        }

        const sortedComments = filteredComments.slice().sort((left, right) => {
          return new Date(right.createdAt).getTime() - new Date(left.createdAt).getTime();
        });

        sortedComments.forEach((comment) => {
          commentAdminList.append(createCommentAdminRow(comment));
        });
      };

      const openCommentAdminDialog = () => {
        if (!isCommentAdmin() || !commentAdminDialog) {
          return;
        }

        closeCommentPanel();
        commentAdminDialog.hidden = false;
        renderCommentAdminDialog();
      };

      const toggleCommentAdminDialog = () => {
        if (!isCommentAdmin() || !commentAdminDialog) {
          return;
        }

        if (!commentAdminDialog.hidden) {
          closeCommentAdminDialog();
          return;
        }

        openCommentAdminDialog();
      };

      const isCommentPressTarget = (target) => {
        if (!(target instanceof HTMLElement)) {
          return false;
        }

        if (target.closest("[data-node-button]")) {
          return true;
        }

        return !target.closest(
          "a, button, input, textarea, label, .mega-observer-panel, .mega-panel-reopen, .mega-comment-popover, .mega-comment-admin-dialog, .mega-comment-pin"
        );
      };

      const consumeCommentPressClick = (event) => {
        if (!commentReleaseClickPoint) {
          return false;
        }

        const dx = event.clientX - commentReleaseClickPoint.x;
        const dy = event.clientY - commentReleaseClickPoint.y;

        if (Math.hypot(dx, dy) > 16) {
          return false;
        }

        commentReleaseClickPoint = null;
        event.preventDefault();
        event.stopPropagation();
        return true;
      };

      const createCommentRow = (comment, compact = false) => {
        const row = document.createElement("article");
        row.className = `mega-comment-row is-${comment.status}`;
        row.dataset.commentId = comment.id;

        const meta = document.createElement("span");
        meta.textContent = `${comment.author} / ${formatCommentTime(comment.createdAt)}`;
        const text = document.createElement("p");
        text.textContent = comment.text;
        row.append(text, meta);
        return row;
      };

      const appendCommentDeleteAction = (row, comment) => {
        if (!row || !canManageComment(comment)) {
          return row;
        }

        const actions = document.createElement("div");
        actions.className = "mega-comment-row-actions";

        const remove = document.createElement("button");
        remove.type = "button";
        remove.dataset.commentAction = "delete";
        remove.dataset.commentId = comment.id;
        remove.textContent = "删除";

        actions.append(remove);
        row.append(actions);
        return row;
      };

      const renderCommentMarkers = () => {
        if (!commentLayer) {
          return;
        }

        commentLayer.textContent = "";

        if (!areCommentsVisible) {
          return;
        }

        const visibleComments = comments.filter(
          (comment) => isCommentAdmin() || comment.status === "approved" || comment.userId === currentCommentUserId
        );

        visibleComments.forEach((comment, index) => {
          const pin = document.createElement("button");
          pin.type = "button";
          pin.className = `mega-comment-pin is-${comment.status}`;
          pin.style.left = `${comment.x}%`;
          pin.style.top = `${comment.y}%`;
          pin.dataset.commentId = comment.id;
          pin.setAttribute("aria-label", `Comment ${index + 1} ${comment.status}`);
          pin.textContent = String(index + 1).padStart(2, "0");
          commentLayer.append(pin);
        });
      };

      const renderCommentUi = () => {
        const isLoggedIn = Boolean(currentCommentUser);
        const adminMode = isCommentAdmin();
        const isViewingComment = Boolean(selectedCommentId);

        updateCommentVisibilityControl();
        if (commentAuth) commentAuth.hidden = isLoggedIn || isViewingComment;
        if (commentSessionPanel) commentSessionPanel.hidden = !isLoggedIn || isViewingComment;
        if (commentForm) commentForm.hidden = !isLoggedIn || isViewingComment;
        if (commentUser) {
          commentUser.textContent = isLoggedIn
            ? `${adminMode ? "管理员" : "用户"} / ${currentCommentUser}`
            : "用户 / -";
        }

        if (commentList) {
          commentList.textContent = "";
          commentList.hidden = isViewingComment;
          const visibleLog = currentCommentUserId
            ? (adminMode ? [] : comments.filter((comment) => comment.userId === currentCommentUserId).slice(0, 4))
            : [];

          if (!isViewingComment && visibleLog.length) {
            const label = document.createElement("span");
            label.textContent = adminMode ? "全部评论" : "我的评论";
            commentList.append(
              label,
              ...visibleLog.map((comment) => appendCommentDeleteAction(createCommentRow(comment, true), comment))
            );
          }
        }

        if (commentReview && commentReviewList) {
          commentReview.hidden = true;
          commentReviewList.textContent = "";
        }

        renderCommentAdminDialog();
        renderCommentMarkers();
      };

      const loadCommentState = async () => {
        if (!hasRemoteComments) {
          if (commentTitle) commentTitle.textContent = "评论服务未配置";
          renderCommentUi();
          return;
        }

        try {
          await restoreCommentSession();
          await loadRemoteComments();
        } catch (error) {
          console.warn("Comment load failed", error);
          if (commentTitle) commentTitle.textContent = "评论加载失败";
        }

        renderCommentUi();
      };

      const authenticateCommentUser = async (mode) => {
        const isRegister = mode === "register";
        const name = normalizeCommentName(commentName?.value);
        const rawName = String(commentName?.value || "");
        const email = normalizeCommentEmail(commentEmail?.value || (rawName.includes("@") ? rawName : ""));
        const password = String(commentPassword?.value || "");

        if (!hasRemoteComments) {
          if (commentTitle) commentTitle.textContent = "评论服务未配置";
          return;
        }

        if (isRegister && !name) {
          if (commentTitle) commentTitle.textContent = "请输入名称";
          return;
        }

        if (!email) {
          if (commentTitle) commentTitle.textContent = "请输入账号邮箱";
          return;
        }

        if (password.length < 6) {
          if (commentTitle) commentTitle.textContent = "密码至少 6 位";
          return;
        }

        try {
          if (isRegister) {
            const emailRegistered = await getCommentEmailRegistered(email);

            if (emailRegistered) {
              if (commentTitle) commentTitle.textContent = "邮箱已经注册";
              return;
            }
          } else {
            const lockStatus = await getCommentLockStatus(email);

            if (lockStatus.isLocked) {
              if (commentTitle) commentTitle.textContent = "账号已锁定，请联系管理员处理";
              return;
            }
          }

          const data = await requestCommentApi(
            isRegister ? "/auth/v1/signup" : "/auth/v1/token?grant_type=password",
            {
              method: "POST",
              body: JSON.stringify(
                isRegister
                  ? { email, password, data: { display_name: name } }
                  : { email, password }
              )
            },
            false
          );
          const session = data.session || (data.access_token ? data : null);

          if (!session) {
            if (commentTitle) commentTitle.textContent = isRegister
              ? "注册成功，请先确认邮箱"
              : "邮箱未确认，请检查注册邮箱的确认邮件";
            return;
          }

          await applyCommentSession(session);

          if (currentCommentLocked) {
            await requestCommentApi("/auth/v1/logout", { method: "POST" }).catch((error) => {
              console.warn("Locked comment logout request failed", error);
            });
            commentSession = null;
            currentCommentUser = "";
            currentCommentUserId = "";
            currentCommentRole = "user";
            currentCommentLocked = false;
            saveCommentSession();
            renderCommentUi();
            if (commentTitle) commentTitle.textContent = "账号已锁定，请联系管理员处理";
            return;
          }

          if (!isRegister) {
            await clearCommentLoginFailures().catch((error) => {
              console.warn("Comment login failure counter clear failed", error);
            });
            await loadCurrentCommentProfile().catch((error) => {
              console.warn("Comment profile reload failed", error);
            });
          }

          await loadRemoteComments();
          if (commentPassword) commentPassword.value = "";
          renderCommentUi();
          if (commentTitle) commentTitle.textContent = isCommentAdmin() ? "管理员已登录" : "已登录";
          trackMegastructureVisit("login");
          commentText?.focus({ preventScroll: true });
        } catch (error) {
          console.warn("Comment auth failed", error);
          const message = String(error?.message || error || "");

          if (!isRegister && /invalid login credentials/i.test(message)) {
            try {
              const lockStatus = await registerCommentLoginFailure(email);

              if (lockStatus.isLocked) {
                if (commentTitle) commentTitle.textContent = "密码错误已超过 3 次，账号已锁定";
              } else if (lockStatus.emailRegistered) {
                const remain = Math.max(0, 3 - lockStatus.failedCount);
                if (commentTitle) commentTitle.textContent = `密码错误，还剩 ${remain} 次机会`;
              } else if (commentTitle) {
                commentTitle.textContent = "账号邮箱或密码错误";
              }
            } catch (lockError) {
              console.warn("Comment login failure counter failed", lockError);
              if (commentTitle) commentTitle.textContent = commentErrorText(lockError, "账号邮箱或密码错误");
            }
            return;
          }

          if (commentTitle) commentTitle.textContent = commentErrorText(error, isRegister ? "注册失败" : "登录失败");
        }
      };

      const submitComment = async () => {
        const text = String(commentText?.value || "").trim();

        if (!currentCommentUserId || !commentDraftPoint || !text) {
          if (commentTitle) commentTitle.textContent = "请先登录";
          return;
        }

        if (currentCommentLocked) {
          if (commentTitle) commentTitle.textContent = "账号已锁定，请联系管理员处理";
          return;
        }

        try {
          await requestCommentApi(
            "/rest/v1/megastructure_comments",
            {
              method: "POST",
              headers: { Prefer: "return=representation" },
              body: JSON.stringify({
                page: commentPageForScene(commentDraftPoint.sceneId || activeSceneId),
                user_id: currentCommentUserId,
                body: text.slice(0, 180),
                x: Number(commentDraftPoint.x.toFixed(2)),
                y: Number(commentDraftPoint.y.toFixed(2)),
                status: "pending"
              })
            }
          );

          await loadRemoteComments();
          if (commentText) commentText.value = "";
          if (commentTitle) commentTitle.textContent = "已提交审核";
          renderCommentUi();
        } catch (error) {
          console.warn("Comment submit failed", error);
          if (commentTitle) commentTitle.textContent = "提交失败";
        }
      };

      const reviewComment = async (id, status) => {
        if (!isCommentAdmin()) {
          if (commentTitle) commentTitle.textContent = "仅管理员可操作";
          return;
        }

        try {
          await requestCommentApi(
            `/rest/v1/megastructure_comments?id=eq.${encodeURIComponent(id)}`,
            {
              method: "PATCH",
              headers: { Prefer: "return=representation" },
              body: JSON.stringify({
                status,
                reviewed_at: new Date().toISOString(),
                review_reason: status === "approved" ? "管理员人工通过。" : "管理员人工拒绝。",
                review_score: status === "approved" ? 0 : 1,
                review_labels: ["manual_review"],
                reviewed_by: "admin"
              })
            }
          );
          await loadRemoteComments();
          renderCommentUi();
        } catch (error) {
          console.warn("Comment review failed", error);
          if (commentTitle) commentTitle.textContent = "审核失败";
        }
      };

      const deleteComment = async (id) => {
        const comment = comments.find((item) => item.id === id);

        if (!comment) {
          return;
        }

        if (!canManageComment(comment)) {
          if (commentTitle) commentTitle.textContent = "无权删除";
          return;
        }

        try {
          await requestCommentApi(`/rest/v1/megastructure_comments?id=eq.${encodeURIComponent(id)}`, {
            method: "DELETE"
          });

          comments = comments.filter((item) => item.id !== id);
          if (selectedCommentId === id) {
            selectedCommentId = "";
          }
          setCommentDetail(null);
          renderCommentUi();
          if (commentTitle) commentTitle.textContent = "已删除";
        } catch (error) {
          console.warn("Comment delete failed", error);
          if (commentTitle) commentTitle.textContent = "删除失败";
        }
      };

      const applyMode = (modeId) => {
        const mode = findMode(modeId);
        activeModeId = mode.id;
        lab.style.setProperty("--mode-accent", mode.accent);
        lab.style.setProperty("--mode-haze", mode.haze);
        if (modeCode) modeCode.textContent = mode.code;

        modeButtons.forEach((button) => {
          const isActive = button.dataset.modeButton === mode.id;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });

        nodeButtons.forEach((button) => {
          button.classList.toggle("is-muted", button.dataset.nodeMode !== mode.id);
        });

        if (lowOscillator && overtoneOscillator) {
          const modeIndex = modes.findIndex((item) => item.id === mode.id);
          const baseFrequency = 56 + modeIndex * 6;
          lowOscillator.frequency.setTargetAtTime(baseFrequency, audioContext.currentTime, 0.08);
          overtoneOscillator.frequency.setTargetAtTime(baseFrequency * 2.35, audioContext.currentTime, 0.08);
        }
      };

      const setPanelCollapsed = (collapsed) => {
        isPanelCollapsed = collapsed;
        lab.classList.toggle("is-panel-collapsed", collapsed);
        if (collapsed) {
          resetPanelPlacement();
        }

        if (observerPanel) {
          observerPanel.setAttribute("aria-hidden", String(collapsed));
        }

        if (panelCollapseButton) {
          panelCollapseButton.setAttribute("aria-expanded", String(!collapsed));
        }

        if (panelReopenButton) {
          panelReopenButton.setAttribute("aria-expanded", String(!collapsed));
          panelReopenButton.setAttribute("aria-hidden", String(!collapsed));
          panelReopenButton.setAttribute("tabindex", collapsed ? "0" : "-1");
        }

        nodeButtons.forEach((button) => {
          const isActive = button.dataset.nodeButton === activeNodeId;
          button.setAttribute("aria-expanded", String(isActive && !collapsed));
        });
      };

      const resetPanelPlacement = () => {
        if (!observerPanel) {
          return;
        }

        observerPanel.style.left = "";
        observerPanel.style.top = "";
        observerPanel.style.right = "";
        observerPanel.style.bottom = "";
        observerPanel.style.width = "";
        observerPanel.style.height = "";
        lab.classList.remove("is-panel-floating");
      };

      const getPanelBounds = () => {
        const stage = lab.querySelector(".mega-lab-stage");

        if (!observerPanel || !stage) {
          return null;
        }

        const stageRect = stage.getBoundingClientRect();
        const panelRect = observerPanel.getBoundingClientRect();
        const gutter = stageRect.width <= 720 ? 14 : 24;
        const viewportLeft = Math.max(stageRect.left, 0);
        const viewportTop = Math.max(stageRect.top, 0);
        const viewportRight = Math.min(stageRect.right, window.innerWidth);
        let viewportBottom = Math.min(stageRect.bottom, window.innerHeight);
        const designStrip = lab.querySelector(".mega-design-strip");
        const designStripRect = designStrip?.getBoundingClientRect();

        if (
          designStripRect &&
          designStripRect.top < window.innerHeight &&
          designStripRect.bottom > 0
        ) {
          viewportBottom = Math.min(viewportBottom, designStripRect.top);
        }

        const safeLeft = Math.max(gutter, viewportLeft - stageRect.left + gutter);
        const safeTop = Math.max(gutter, viewportTop - stageRect.top + gutter);
        const safeRight = Math.max(
          safeLeft + 1,
          Math.min(stageRect.width - gutter, viewportRight - stageRect.left - gutter)
        );
        const safeBottom = Math.max(
          safeTop + 1,
          Math.min(stageRect.height - gutter, viewportBottom - stageRect.top - gutter)
        );
        const preferredMinWidth = stageRect.width <= 720 ? 220 : 260;
        const preferredMinHeight = stageRect.width <= 720 ? 220 : 240;
        const availableWidth = Math.max(1, safeRight - safeLeft);
        const availableHeight = Math.max(1, safeBottom - safeTop);
        const minWidth = Math.min(preferredMinWidth, availableWidth);
        const minHeight = Math.min(preferredMinHeight, availableHeight);
        const maxWidth = Math.max(minWidth, availableWidth);
        const maxHeight = Math.max(minHeight, availableHeight);

        return {
          stageRect,
          gutter,
          safeLeft,
          safeTop,
          safeRight,
          safeBottom,
          minWidth,
          minHeight,
          maxWidth,
          maxHeight,
          left: panelRect.left - stageRect.left,
          top: panelRect.top - stageRect.top,
          width: panelRect.width,
          height: panelRect.height
        };
      };

      const isPanelManuallyFloating = () => lab.classList.contains("is-panel-floating");

      const getPanelContentHeight = (width) => {
        if (!observerPanel) {
          return 0;
        }

        const previousWidth = observerPanel.style.width;
        const previousHeight = observerPanel.style.height;
        const previousMaxHeight = observerPanel.style.maxHeight;
        observerPanel.style.width = `${width}px`;
        observerPanel.style.height = "auto";
        observerPanel.style.maxHeight = "none";

        const panelStyle = getComputedStyle(observerPanel);
        const borderHeight =
          Number.parseFloat(panelStyle.borderTopWidth || "0") +
          Number.parseFloat(panelStyle.borderBottomWidth || "0");
        const contentHeight = Math.ceil(observerPanel.scrollHeight + borderHeight);

        observerPanel.style.width = previousWidth;
        observerPanel.style.height = previousHeight;
        observerPanel.style.maxHeight = previousMaxHeight;

        return contentHeight;
      };

      const applyFloatingPanelBox = (box) => {
        if (!observerPanel) {
          return;
        }

        const bounds = getPanelBounds();

        if (!bounds) {
          return;
        }

        const width = clamp(box.width, bounds.minWidth, bounds.maxWidth);
        const contentHeight = getPanelContentHeight(width);
        const height = Math.max(clamp(box.height, bounds.minHeight, bounds.maxHeight), contentHeight);
        const left = clamp(box.left, bounds.safeLeft, Math.max(bounds.safeLeft, bounds.safeRight - width));
        const top = clamp(box.top, bounds.safeTop, Math.max(bounds.safeTop, bounds.safeBottom - height));

        observerPanel.style.left = `${left}px`;
        observerPanel.style.top = `${top}px`;
        observerPanel.style.right = "auto";
        observerPanel.style.bottom = "auto";
        observerPanel.style.width = `${width}px`;
        observerPanel.style.height = `${height}px`;
        lab.classList.add("is-panel-floating");
      };

      const applyDockedPanelBox = (box) => {
        if (!observerPanel) {
          return;
        }

        const bounds = getPanelBounds();

        if (!bounds) {
          return;
        }

        const width = clamp(box.width, bounds.minWidth, bounds.maxWidth);
        const contentHeight = getPanelContentHeight(width);
        const height = Math.max(clamp(box.height, bounds.minHeight, bounds.maxHeight), contentHeight);
        const right = Math.max(bounds.gutter, bounds.stageRect.width - bounds.safeRight);
        const bottom = Math.max(bounds.gutter, bounds.stageRect.height - bounds.safeBottom);

        observerPanel.style.left = "auto";
        observerPanel.style.top = "auto";
        observerPanel.style.right = `${right}px`;
        observerPanel.style.bottom = `${bottom}px`;
        observerPanel.style.width = `${width}px`;
        observerPanel.style.height = `${height}px`;
        lab.classList.remove("is-panel-floating");
      };

      const schedulePanelBox = (box, mode = "floating") => {
        pendingPanelBox = box;
        pendingPanelMode = mode;

        if (panelFrame) {
          return;
        }

        panelFrame = window.requestAnimationFrame(() => {
          panelFrame = 0;
          if (pendingPanelMode === "docked") {
            applyDockedPanelBox(pendingPanelBox);
          } else {
            applyFloatingPanelBox(pendingPanelBox);
          }
          pendingPanelBox = null;
          pendingPanelMode = "floating";
        });
      };

      const isPanelFreeformEnabled = () => window.matchMedia("(min-width: 721px)").matches;

      const startPanelGesture = (event, type) => {
        if (!observerPanel || !isPanelFreeformEnabled()) {
          return;
        }

        const target = event.target;

        if (
          type === "move" &&
          target instanceof HTMLElement &&
          target.closest("button, input, a, label")
        ) {
          return;
        }

        const bounds = getPanelBounds();

        if (!bounds) {
          return;
        }

        panelGesture = {
          type,
          mode: type === "resize" && !isPanelManuallyFloating() ? "docked" : "floating",
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          left: bounds.left,
          top: bounds.top,
          width: bounds.width,
          height: bounds.height
        };

        observerPanel.setPointerCapture?.(event.pointerId);
        lab.classList.add("is-panel-adjusting");
        event.preventDefault();
      };

      const updatePanelGesture = (event) => {
        if (!panelGesture || event.pointerId !== panelGesture.pointerId) {
          return;
        }

        const dx = event.clientX - panelGesture.startX;
        const dy = event.clientY - panelGesture.startY;

        if (panelGesture.type === "resize") {
          if (panelGesture.mode === "docked") {
            schedulePanelBox(
              {
                left: panelGesture.left,
                top: panelGesture.top,
                width: panelGesture.width - dx,
                height: panelGesture.height - dy
              },
              "docked"
            );
          } else {
            schedulePanelBox({
              left: panelGesture.left + dx,
              top: panelGesture.top + dy,
              width: panelGesture.width - dx,
              height: panelGesture.height - dy
            });
          }
        } else {
          schedulePanelBox({
            left: panelGesture.left + dx,
            top: panelGesture.top + dy,
            width: panelGesture.width,
            height: panelGesture.height
          });
        }
      };

      const endPanelGesture = (event) => {
        if (!panelGesture || event.pointerId !== panelGesture.pointerId) {
          return;
        }

        panelGesture = null;
        lab.classList.remove("is-panel-adjusting");
      };

      const adjustPanelSize = (widthDelta, heightDelta) => {
        const bounds = getPanelBounds();

        if (!bounds || !isPanelFreeformEnabled()) {
          return;
        }

        const box = {
          left: bounds.left,
          top: bounds.top,
          width: bounds.width + widthDelta,
          height: bounds.height + heightDelta
        };

        if (isPanelManuallyFloating()) {
          applyFloatingPanelBox(box);
        } else {
          applyDockedPanelBox(box);
        }
      };

      const clampPanelPlacement = () => {
        if (
          !observerPanel ||
          lab.classList.contains("is-panel-collapsed") ||
          !isPanelFreeformEnabled()
        ) {
          return;
        }

        const bounds = getPanelBounds();

        if (!bounds) {
          return;
        }

        if (isPanelManuallyFloating()) {
          applyFloatingPanelBox(bounds);
        } else {
          applyDockedPanelBox(bounds);
        }
      };

      const clearNodeFocus = () => {
        activeNodeId = "";
        lab.classList.add("is-node-unfocused");
        lab.dataset.focusState = "none";
        lab.style.setProperty("--focus-x", "50%");
        lab.style.setProperty("--focus-y", "50%");
        lab.style.setProperty("--map-x", "50%");
        lab.style.setProperty("--map-y", "50%");

        nodeButtons.forEach((button) => {
          button.classList.remove("is-active");
          button.setAttribute("aria-pressed", "false");
          button.setAttribute("aria-expanded", "false");
        });

        if (locatorCode) locatorCode.textContent = "NULL";
        setPanelCollapsed(true);
      };

      const reloadCommentsForActiveScene = () => {
        closeCommentPanel();
        comments = commentCache.get(commentPageForScene(activeSceneId)) || [];
        renderCommentUi();
        trackMegastructureVisit("view");

        if (!hasRemoteComments) {
          return;
        }

        loadRemoteComments(activeSceneId)
          .then(renderCommentUi)
          .catch((error) => {
            comments = [];
            renderCommentUi();
            console.warn("Scene comments reload failed", error);
          });
      };

      const enterScene = (sceneId, options = {}) => {
        const targetScene = findScene(sceneId);
        const routeNode = options.routeNode || null;
        const shouldRecordHistory = options.recordHistory !== false;
        const fromSceneId = activeSceneId;
        const landingNode = nodeForScene(targetScene.id);

        if (shouldRecordHistory && targetScene.id !== fromSceneId) {
          sceneHistory.push(fromSceneId);
        }

        activeNodeId = landingNode.id;
        lastNodeId = landingNode.id;
        lab.classList.remove("is-node-unfocused");
        lab.dataset.focusState = "route";
        applyScene(targetScene.id);
        lab.style.setProperty("--focus-x", String(landingNode.x) + "%");
        lab.style.setProperty("--focus-y", String(landingNode.y) + "%");
        lab.style.setProperty("--map-x", String(landingNode.x) + "%");
        lab.style.setProperty("--map-y", String(landingNode.y) + "%");

        nodeButtons.forEach((button) => {
          const isActive = button.dataset.nodeButton === landingNode.id;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });

        if (nodeCode) nodeCode.textContent = landingNode.code;
        if (nodeTitle) nodeTitle.textContent = landingNode.label;
        const landingDescription = nodeTargetDescription(landingNode);

        if (nodeSentence) nodeSentence.textContent = landingDescription;
        if (nodeSignal) nodeSignal.textContent = landingNode.signal;
        if (reopenCode) reopenCode.textContent = landingNode.code;
        if (locatorCode) locatorCode.textContent = landingNode.code;
        setSignalQuality(landingNode);
        setPanelViewport(landingNode);
        updateRouteUi(routeNode);

        applyMode(landingNode.mode);

        if (options.reloadComments !== false) {
          reloadCommentsForActiveScene();
        }
      };

      const applyNode = (nodeId, options = {}) => {
        const routeNode = findNode(nodeId);
        const targetScene = findScene(routeNode.targetScene || routeNode.scene);

        enterScene(targetScene.id, {
          recordHistory: options.recordHistory !== false,
          routeNode
        });
      };

      const setScale = (value) => {
        const normalized = Number(value || 0);
        const nextScale = 1 + normalized / 420;
        lab.style.setProperty("--stage-scale", String(nextScale));
        lab.style.setProperty("--pressure", String(normalized));
        if (scaleValue) scaleValue.textContent = String(normalized);
      };

      const toggleAudio = async () => {
        const AudioCtor = window.AudioContext || window.webkitAudioContext;
        if (!AudioCtor || !audioButton) {
          return;
        }

        if (!audioContext) {
          audioContext = new AudioCtor();
          lowOscillator = audioContext.createOscillator();
          overtoneOscillator = audioContext.createOscillator();
          lowGain = audioContext.createGain();
          presenceGain = audioContext.createGain();
          gain = audioContext.createGain();
          const modeIndex = modes.findIndex((item) => item.id === activeModeId);
          const baseFrequency = 56 + modeIndex * 6;
          lowOscillator.type = "sine";
          overtoneOscillator.type = "sine";
          lowOscillator.frequency.value = baseFrequency;
          overtoneOscillator.frequency.value = baseFrequency * 2.35;
          lowGain.gain.value = 0.9;
          presenceGain.gain.value = 0.32;
          gain.gain.value = 0.0001;
          lowOscillator.connect(lowGain);
          overtoneOscillator.connect(presenceGain);
          lowGain.connect(gain);
          presenceGain.connect(gain);
          gain.connect(audioContext.destination);
          lowOscillator.start();
          overtoneOscillator.start();
        }

        const isOn = audioButton.getAttribute("aria-pressed") !== "true";
        audioButton.setAttribute("aria-pressed", String(isOn));
        audioButton.textContent = isOn ? "静音" : "低频";
        gain.gain.setTargetAtTime(isOn ? 0.036 : 0.0001, audioContext.currentTime, 0.08);
        lab.dataset.audioState = isOn ? "on" : "off";

        if (audioContext.state === "suspended") {
          await audioContext.resume().catch(() => {
            lab.dataset.audioState = "blocked";
          });
        }

        if (isOn && audioContext.state === "running") {
          gain.gain.setTargetAtTime(0.036, audioContext.currentTime, 0.08);
          lab.dataset.audioState = "running";
        }
      };

      modeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const modeId = button.dataset.modeButton;
          const firstNodeInMode = nodes.find((node) => node.scene === activeSceneId && node.mode === modeId)
            || nodes.find((node) => node.mode === modeId);
          applyNode(firstNodeInMode ? firstNodeInMode.id : activeNodeId || nodes[0].id);
        });
      });

      nodeButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          if (consumeCommentPressClick(event)) {
            return;
          }

          applyNode(button.dataset.nodeButton);
        });
      });

      audioButton?.addEventListener("click", () => {
        toggleAudio();
      });

      panelCollapseButton?.addEventListener("click", () => {
        clearNodeFocus();
        panelReopenButton?.focus({ preventScroll: true });
      });

      panelReopenButton?.addEventListener("click", () => {
        if (activeNodeId) {
          resetPanelPlacement();
          setPanelCollapsed(false);
          return;
        }

        applyNode(lastNodeId || nodes[0].id);
      });

      scaleRange?.addEventListener("input", () => {
        setScale(scaleRange.value);
      });

      routeBackButton?.addEventListener("click", () => {
        const previousSceneId = sceneHistory.pop();

        if (!previousSceneId) {
          updateRouteUi();
          return;
        }

        enterScene(previousSceneId, { recordHistory: false });
      });

      panelDragHandle?.addEventListener("pointerdown", (event) => {
        startPanelGesture(event, "move");
      });

      panelResizeHandle?.addEventListener("pointerdown", (event) => {
        startPanelGesture(event, "resize");
      });

      observerPanel?.addEventListener("pointermove", (event) => {
        updatePanelGesture(event);
      });

      observerPanel?.addEventListener("pointerup", (event) => {
        endPanelGesture(event);
      });

      observerPanel?.addEventListener("lostpointercapture", (event) => {
        endPanelGesture(event);
      });

      panelResizeHandle?.addEventListener("keydown", (event) => {
        const step = event.shiftKey ? 48 : 16;

        if (event.key === "ArrowRight") {
          adjustPanelSize(step, 0);
        } else if (event.key === "ArrowLeft") {
          adjustPanelSize(-step, 0);
        } else if (event.key === "ArrowDown") {
          adjustPanelSize(0, step);
        } else if (event.key === "ArrowUp") {
          adjustPanelSize(0, -step);
        } else {
          return;
        }

        event.preventDefault();
      });

      commentLoginButton?.addEventListener("click", () => {
        authenticateCommentUser("login");
      });

      commentRegisterButton?.addEventListener("click", () => {
        authenticateCommentUser("register");
      });

      commentLogoutButton?.addEventListener("click", async () => {
        if (commentSession?.access_token) {
          requestCommentApi("/auth/v1/logout", { method: "POST" }).catch((error) => {
            console.warn("Comment logout request failed", error);
          });
        }
        commentSession = null;
        currentCommentUser = "";
        currentCommentUserId = "";
        currentCommentRole = "user";
        currentCommentLocked = false;
        saveCommentSession();
        await loadRemoteComments().catch((error) => {
          comments = [];
          console.warn("Public comments reload failed", error);
        });
        renderCommentUi();
      });

      commentCloseButton?.addEventListener("click", () => {
        closeCommentPanel();
      });

      commentAdminOpenButton?.addEventListener("click", () => {
        toggleCommentAdminDialog();
      });

      commentAdminCloseButton?.addEventListener("click", () => {
        closeCommentAdminDialog();
      });

      commentAdminFilterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const status = button.dataset.commentAdminFilter || "";

          if (!commentAdminFilterStatuses.includes(status)) {
            return;
          }

          activeCommentAdminFilter = status;
          renderCommentAdminDialog();
        });
      });

      commentToggleButton?.addEventListener("click", () => {
        setCommentsVisible(!areCommentsVisible);
      });

      commentForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        submitComment();
      });

      commentLayer?.addEventListener("click", (event) => {
        if (!areCommentsVisible) {
          return;
        }

        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const pin = target.closest("[data-comment-id]");
        const comment = comments.find((item) => item.id === pin?.dataset.commentId);

        if (comment) {
          openCommentPanel({ x: comment.x, y: comment.y }, comment);
        }
      });

      const handleCommentDeleteClick = (event) => {
        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const button = target.closest("[data-comment-action='delete']");
        const id = button?.dataset.commentId;

        if (id) {
          deleteComment(id);
        }
      };

      commentDetail?.addEventListener("click", handleCommentDeleteClick);
      commentList?.addEventListener("click", handleCommentDeleteClick);

      const handleCommentReviewActionClick = (event) => {
        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const button = target.closest("[data-comment-action]");
        const action = button?.dataset.commentAction;
        const id = button?.dataset.commentId;

        if (id && action === "approve") {
          reviewComment(id, "approved");
        } else if (id && action === "reject") {
          reviewComment(id, "rejected");
        } else if (id && action === "delete") {
          deleteComment(id);
        }
      };

      commentReviewList?.addEventListener("click", handleCommentReviewActionClick);
      commentAdminList?.addEventListener("click", handleCommentReviewActionClick);

      document.addEventListener("click", (event) => {
        if (!commentPopover || commentPopover.hidden || Date.now() - commentOpenedAt < 180) {
          return;
        }

        const target = event.target;

        if (!(target instanceof Node)) {
          return;
        }

        if (commentPopover.contains(target)) {
          return;
        }

        if (target instanceof HTMLElement && target.closest(".mega-comment-pin")) {
          return;
        }

        if (commentReleaseClickPoint) {
          const dx = event.clientX - commentReleaseClickPoint.x;
          const dy = event.clientY - commentReleaseClickPoint.y;
          commentReleaseClickPoint = null;

          if (Math.hypot(dx, dy) <= 16) {
            return;
          }
        }

        closeCommentPanel();
      });

      labStage?.addEventListener("pointerdown", (event) => {
        if (event.button !== 0 || panelGesture || !isCommentPressTarget(event.target)) {
          return;
        }

        clearCommentPress();
        commentPressStart = {
          x: event.clientX,
          y: event.clientY,
          point: getCommentPoint(event)
        };
        commentPressTimer = window.setTimeout(() => {
          if (commentPressStart) {
            commentReleaseClickPoint = {
              x: commentPressStart.x,
              y: commentPressStart.y
            };
            openCommentPanel(commentPressStart.point);
          }
          clearCommentPress();
        }, commentHoldMs);
      });

      labStage?.addEventListener(
        "pointermove",
        (event) => {
          if (!commentPressStart) {
            return;
          }

          const dx = event.clientX - commentPressStart.x;
          const dy = event.clientY - commentPressStart.y;

          if (Math.hypot(dx, dy) > 10) {
            clearCommentPress();
          }
        },
        { passive: true }
      );

      ["pointerup", "pointercancel", "pointerleave"].forEach((eventName) => {
        labStage?.addEventListener(eventName, clearCommentPress);
      });

      window.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") {
          return;
        }

        if (commentPopover && !commentPopover.hidden) {
          closeCommentPanel();
        }
        if (commentAdminDialog && !commentAdminDialog.hidden) {
          closeCommentAdminDialog();
        }
      });

      window.addEventListener("resize", clampPanelPlacement);
      window.addEventListener("scroll", clampPanelPlacement, { passive: true });

      lab.addEventListener(
        "pointermove",
        (event) => {
          if (panelGesture || reduceMotion.matches || pointerFrame) {
            return;
          }

          pointerFrame = window.requestAnimationFrame(() => {
            pointerFrame = 0;
            const rect = lab.getBoundingClientRect();
            const x = (event.clientX - rect.left) / Math.max(rect.width, 1) - 0.5;
            const y = (event.clientY - rect.top) / Math.max(rect.height, 1) - 0.5;
            lab.style.setProperty("--drift-x", String(x * -1.2) + "rem");
            lab.style.setProperty("--drift-y", String(y * -0.8) + "rem");
          });
        },
        { passive: true }
      );

      window.addEventListener("beforeunload", () => {
        if (pointerFrame) {
          window.cancelAnimationFrame(pointerFrame);
        }
        if (audioContext) {
          audioContext.close();
        }

        if (panelFrame) {
          window.cancelAnimationFrame(panelFrame);
        }

        clearCommentPress();
      });

      loadCommentVisibilityPreference();
      setScale(scaleRange?.value || "62");
      enterScene(activeSceneId, { recordHistory: false, reloadComments: false });
      loadCommentState();
      lab.dataset.ready = "true";
    }
  </script>
</BaseLayout>

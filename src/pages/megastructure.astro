    targetScene: "lightwell",
    routeLabel: "把轨迹发送到光谱井",
    sentence: "让运动数据继续变成光和颜色。",
    signal: "TRACE / LIGHT"
  },
  {
    ...nodeDefaults,
    id: "ring-to-highland",
    scene: "ring-city",
    mode: "flow",
    label: "风场坡",
    code: "03—02",
    x: 26,
    y: 68,
    labelX: 0,
    labelY: 0,
    labelAlign: "center",
    targetScene: "highland",
    routeLabel: "返回风场坡",
